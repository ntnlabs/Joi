#!/bin/bash
# Joi Admin Tool - Memory and key management
#
# Usage: sudo joi-admin purge [FLAGS]
#
# SAFE BY DEFAULT: No flags = no action. Must explicitly specify what to purge.

set -Eeuo pipefail

SCRIPT_NAME=$(basename "$0")
SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)
JOI_PY_ROOT=$(cd "$SCRIPT_DIR/.." && pwd)
MEMORY_DB="${JOI_MEMORY_DB:-/var/lib/joi/memory.db}"
NONCE_DB="${JOI_NONCE_DB:-/var/lib/joi/nonces.db}"
HMAC_KEY_FILE="${JOI_HMAC_KEY_FILE:-/etc/joi/hmac.key}"
MEMORY_KEY_FILE="${JOI_MEMORY_KEY_FILE:-/etc/joi/memory.key}"
SQLCIPHER_BIN="${JOI_SQLCIPHER_BIN:-sqlcipher}"
NEBULA_DIR="/etc/nebula"
SERVICE_USER="${JOI_SERVICE_USER:-joi}"
DB_MODE=""
DB_KEY=""
DB_MODE_INITIALIZED=false

# Colors for output
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color
DEBUG="${JOI_ADMIN_DEBUG:-0}"

if [[ "$DEBUG" == "1" ]]; then
    set -x
fi

on_err() {
    local exit_code=$?
    echo -e "${RED}Error at line ${BASH_LINENO[0]}: ${BASH_COMMAND} (exit ${exit_code})${NC}" >&2
    exit "$exit_code"
}

trap on_err ERR

usage() {
    cat << 'EOF'
Joi Admin Tool

USAGE:
    joi-admin <COMMAND> [OPTIONS]

COMMANDS:
    purge       Purge memory data and/or regenerate keys
    facts       Inspect and delete stored user facts
    reminders   Inspect and clear reminders
    rag         Inspect and manage RAG knowledge sources/scopes
    summaries   Read-only context summary inspection
    fts         Check and rebuild FTS (full-text search) indexes
    wind        Inspect and manage Wind proactive messaging state
    nuke        Drop ALL tables in the memory database (irreversible)

PURGE USAGE:
    joi-admin purge [FLAGS]

    SAFE BY DEFAULT: Running without flags does nothing.

DATA FLAGS (what to delete):
    --contexts          Delete messages and context summaries
    --facts             Delete learned user facts
    --knowledge         Delete RAG knowledge chunks
    --all-data          All of the above (contexts + facts + knowledge)

RESET FLAGS:
    --reset-counters    Reset AUTOINCREMENT counters (sqlite_sequence) for
                        messages, user_facts, context_summaries, knowledge_chunks
                        Requires global full-memory purge (no --conversation)
    --vacuum            Compact memory DB file after purge (VACUUM)
                        Requires global full-memory purge (no --conversation)
                        Shows extra warnings and asks for double confirmation

SCOPE FLAGS (limit deletion):
    --conversation ID   Only affect specific conversation (phone/group ID)
                        Without this, affects ALL conversations

KEY FLAGS:
    --hmac-key          Regenerate HMAC signing key
    --nebula-keys       Remove Nebula host keys (requires re-enrollment)
    --all-keys          Both HMAC and Nebula keys

NUCLEAR OPTIONS:
    --everything        Equivalent to --all-data --all-keys
    --nebula-ca         Also remove Nebula CA cert (true factory reset)

EXAMPLES:
    joi-admin purge                                    # Does nothing (safe)
    joi-admin purge --contexts                         # Clear all conversation history
    joi-admin purge --contexts --conversation +1234    # Clear one conversation (//reload)
    joi-admin purge --contexts --facts --conversation +1234  # //restart equivalent
    joi-admin purge --all-data --conversation +1234    # //reset equivalent
    joi-admin purge --all-data --reset-counters        # Full data purge + ID counters reset
    joi-admin purge --all-data --reset-counters --vacuum
    joi-admin purge --all-data --all-keys              # Customer handoff
    joi-admin purge --everything --nebula-ca           # True factory reset

RAG USAGE:
    joi-admin rag <SUBCOMMAND> [OPTIONS]

RAG SUBCOMMANDS:
    list                List RAG knowledge sources
    scopes              List unique RAG scopes with totals
    stats               Show RAG totals
    delete              Delete a RAG source (optionally within one scope)
    rescope             Move RAG chunks from one scope to another
    orphans             Check/clean orphaned chunks (empty scope)

RAG EXAMPLES:
    joi-admin rag list
    joi-admin rag scopes
    joi-admin rag stats
    joi-admin rag delete --source '+123456789/diary.txt' --scope -123456789
    joi-admin rag rescope --from +123456789 --to -123456789
    joi-admin rag orphans                     # Check for orphaned chunks
    joi-admin rag orphans --clean             # Delete orphaned chunks

SUMMARIES USAGE:
    joi-admin summaries list [--conversation ID] [--limit N]
    joi-admin summaries show --id ID
    joi-admin summaries delete --id ID

SUMMARIES EXAMPLES:
    joi-admin summaries list
    joi-admin summaries list --conversation +123456789
    joi-admin summaries list --conversation group_id_here --limit 20
    joi-admin summaries show --id 42
    joi-admin summaries delete --id 42

FTS USAGE:
    joi-admin fts status              Check FTS index integrity
    joi-admin fts rebuild [--index NAME]  Rebuild FTS indexes

FTS INDEXES:
    knowledge_fts     RAG knowledge chunks
    user_facts_fts    User facts
    summaries_fts     Context summaries

FTS EXAMPLES:
    joi-admin fts status                        # Check all FTS indexes
    joi-admin fts rebuild                       # Rebuild all FTS indexes
    joi-admin fts rebuild --index knowledge_fts # Rebuild specific index

FACTS USAGE:
    joi-admin facts <SUBCOMMAND> [OPTIONS]

FACTS SUBCOMMANDS:
    list [--conversation ID] [--category CAT] [--order-by id|date|category|key] [--include-expired]  List stored facts
    show <id>                                   Show full detail for one fact
    add --conversation ID --category CAT --key KEY --value VALUE [--confidence 0.9]  Add a fact manually
    reschedule <id> --expires-in HOURS [--value "new text"]  Reschedule a temporal fact
    delete <id>                                 Delete a single fact by ID
    delete-all [--conversation ID]              Delete all facts (with confirmation)

FACTS EXAMPLES:
    joi-admin facts list                        # All active facts
    joi-admin facts list --include-expired      # Include expired facts
    joi-admin facts list --conversation +123    # Facts for one conversation
    joi-admin facts list --category personal    # Facts in a category
    joi-admin facts show 42                     # Show full detail for fact #42
    joi-admin facts add --conversation +123 --category personal --key birthday --value "January 1"
    joi-admin facts add --conversation +123 --category personal --key job --value "engineer" --confidence 1.0
    joi-admin facts reschedule 42 --expires-in 168          # Reschedule to 1 week from now
    joi-admin facts reschedule 42 --expires-in 48 --value "Meeting moved to Monday 10am"
    joi-admin facts delete 42                   # Delete fact #42
    joi-admin facts delete-all                  # Wipe all facts
    joi-admin facts delete-all --conversation +123  # Wipe facts for one conversation

REMINDERS USAGE:
    joi-admin reminders <SUBCOMMAND> [OPTIONS]

REMINDERS SUBCOMMANDS:
    list [--conversation ID] [--status STATUS] [--order-by id|date]  List reminders (default: all statuses)
    delete-expired                              Delete all reminders past their expiry time
    delete-fired                                Delete all reminders with status 'fired'
    clear [--conversation ID]                   Delete all reminders (with confirmation)

REMINDERS EXAMPLES:
    joi-admin reminders list                    # All reminders
    joi-admin reminders list --conversation +123         # Reminders for one conversation
    joi-admin reminders list --status pending   # Only pending
    joi-admin reminders delete-expired          # Remove stale expired reminders
    joi-admin reminders delete-fired            # Remove already-fired reminders
    joi-admin reminders clear                   # Delete all reminders
    joi-admin reminders clear --conversation +123        # Delete for one conversation

WIND USAGE:
    joi-admin wind <SUBCOMMAND> [OPTIONS]

WIND SUBCOMMANDS:
    show-windmood [conversation_id]   Show WindMood state (threshold offset, accumulated)
    reset-windmood [conversation_id]  Reset WindMood to defaults (offset=NULL, accumulated=0)
    set-windmood <conversation_id>    Fine-tune WindMood values
    show-engagement [conversation_id] Show engagement stats (score, sent/engaged/ignored/deflected)
    reset-engagement [conversation_id] Reset engagement score to 0.5 and clear counters
    show-feedback [conversation_id]   Show per-topic-family feedback (interest/rejection weights, undertaker status)
    clear-cooldowns <conversation_id> Clear all topic family cooldowns
    undertaker-clear <conv_id> <fam>  Remove undertaker flag from a topic family
    undertaker-list <conv_id>         List all undertaker-blocked families
    undertaker-poke <conv_id> [fam]   Queue a playful poke for a random (or named) undertaker family
    snooze <conversation_id> <dur>    Pause Wind for a duration (e.g. 2h, 30m, 1d)
    snooze-clear <conversation_id>    Clear Wind snooze
    revive-topic <id>                 Revive an expired/ignored topic back to pending
    decision-log                      Show recent Wind tick decisions
    topic-list                        List pending topics
    topic-show <id>                   Show full detail for a topic
    topic-delete <id>                 Delete a topic
    topic-purge --conversation ID     Delete all topics for a conversation

WIND OPTIONS:
    --offset VALUE        Set threshold_offset (-0.1 to 0.1)
    --accumulated VALUE   Set accumulated_impulse (>= 0)
    --limit N             Limit results (default varies by subcommand)

WIND EXAMPLES:
    joi-admin wind show-windmood                        # Show all conversations
    joi-admin wind show-windmood +123456789             # Show specific conversation
    joi-admin wind reset-windmood                       # Reset all to defaults
    joi-admin wind reset-windmood +123456789            # Reset specific conversation
    joi-admin wind set-windmood +123 --offset 0.05      # Fine-tune offset
    joi-admin wind set-windmood +123 --accumulated 0.3  # Fine-tune accumulator
    joi-admin wind show-engagement                      # Show all engagement stats
    joi-admin wind show-engagement +123456789           # Show specific conversation
    joi-admin wind reset-engagement                     # Reset all engagement to neutral
    joi-admin wind reset-engagement +123456789          # Reset specific conversation
    joi-admin wind show-feedback +123456789             # Show topic family feedback (incl. undertaker)
    joi-admin wind clear-cooldowns +123456789           # Clear all cooldowns
    joi-admin wind undertaker-clear +123456789 health   # Remove undertaker block from 'health' family
    joi-admin wind undertaker-list +123456789            # Show all undertaker-blocked families
    joi-admin wind undertaker-poke +123456789            # Queue poke for a random undertaker family
    joi-admin wind undertaker-poke +123456789 health     # Queue poke for the 'health' family
    joi-admin wind snooze +123456789 2h                 # Pause Wind for 2 hours
    joi-admin wind snooze-clear +123456789              # Clear snooze
    joi-admin wind revive-topic 7                       # Revive topic #7 back to pending
    joi-admin wind decision-log                         # Show recent tick decisions
    joi-admin wind decision-log --conversation +123456789 --decision skip
    joi-admin wind topic-list --conversation +123456789 # List topics
    joi-admin wind topic-show 8                         # Show topic #8
    joi-admin wind topic-delete 9                       # Delete topic #9
    joi-admin wind topic-purge --conversation +123456789

EOF
    exit 0
}

error() {
    echo -e "${RED}Error: $1${NC}" >&2
    exit 1
}

warn() {
    echo -e "${YELLOW}Warning: $1${NC}" >&2
}

info() {
    echo -e "${GREEN}$1${NC}"
}

# Check if running as root
check_root() {
    if [[ $EUID -ne 0 ]]; then
        error "This script must be run as root (sudo)"
    fi
}

sql_escape_literal() {
    # Escape single quotes for SQL string literals.
    printf "%s" "$1" | sed "s/'/''/g"
}

ensure_db_mode() {
    if $DB_MODE_INITIALIZED; then
        return
    fi
    DB_MODE_INITIALIZED=true

    if [[ ! -f "$MEMORY_DB" ]]; then
        return
    fi

    if command -v sqlite3 >/dev/null 2>&1; then
        # Probe schema access (not just SELECT 1), so encrypted DBs are rejected.
        if sqlite3 "$MEMORY_DB" "SELECT count(*) FROM sqlite_master WHERE type='table';" >/dev/null 2>&1; then
            DB_MODE="sqlite3"
            return
        fi
    fi

    if command -v "$SQLCIPHER_BIN" >/dev/null 2>&1; then
        if [[ -f "$MEMORY_KEY_FILE" ]]; then
            DB_KEY=$(tr -d '\r\n' < "$MEMORY_KEY_FILE")
            if [[ -n "$DB_KEY" ]]; then
                if "$SQLCIPHER_BIN" "$MEMORY_DB" <<EOF >/dev/null 2>&1
PRAGMA key = '$DB_KEY';
SELECT count(*) FROM sqlite_master WHERE type='table';
EOF
                then
                    DB_MODE="sqlcipher_key"
                    return
                fi
            fi
        fi

        # Fallback: sqlcipher can also open plaintext DBs.
        if "$SQLCIPHER_BIN" "$MEMORY_DB" "SELECT count(*) FROM sqlite_master WHERE type='table';" >/dev/null 2>&1; then
            DB_MODE="sqlcipher_plain"
            return
        fi
    fi

    error "Cannot open memory DB ($MEMORY_DB). Install sqlite3/sqlcipher and check JOI_MEMORY_KEY_FILE."
}

db_exec() {
    local sql="$1"
    ensure_db_mode

    if [[ "$DEBUG" == "1" ]]; then
        echo "[DEBUG] DB mode: ${DB_MODE}" >&2
        echo "[DEBUG] SQL: ${sql}" >&2
    fi

    case "$DB_MODE" in
        sqlite3)
            sqlite3 "$MEMORY_DB" "$sql"
            ;;
        sqlcipher_key)
            "$SQLCIPHER_BIN" "$MEMORY_DB" <<EOF
PRAGMA key = '$DB_KEY';
$sql
EOF
            ;;
        sqlcipher_plain)
            "$SQLCIPHER_BIN" "$MEMORY_DB" "$sql"
            ;;
        *)
            error "Database engine not initialized"
            ;;
    esac
}

db_scalar() {
    local sql="$1"
    local output
    output=$(db_exec "$sql")

    # sqlcipher can emit a standalone "ok" line from PRAGMA key.
    # Return first real scalar value.
    printf "%s\n" "$output" | awk 'NF && $0 != "ok" { print; exit }'
}

_FTS5_AVAILABLE=""   # empty = unchecked, "yes" or "no"

check_fts5_available() {
    if [[ -n "$_FTS5_AVAILABLE" ]]; then return; fi
    if db_exec "SELECT count(*) FROM knowledge_fts LIMIT 1;" >/dev/null 2>&1; then
        _FTS5_AVAILABLE="yes"
    else
        _FTS5_AVAILABLE="no"
    fi
}

restore_knowledge_fts_with_python() {
    # Fallback recovery path for sqlcipher CLI builds without FTS5:
    # use Joi's Python MemoryStore (which typically has working FTS5 support)
    # to recreate missing triggers and rebuild the FTS index.
    if ! command -v python3 >/dev/null 2>&1; then
        warn "python3 not available; cannot restore knowledge FTS triggers automatically."
        return 1
    fi

    local py_err=""
    if ! py_err=$(PYTHONPATH="$JOI_PY_ROOT${PYTHONPATH:+:$PYTHONPATH}" \
        JOI_MEMORY_DB="$MEMORY_DB" \
        JOI_MEMORY_KEY_FILE="$MEMORY_KEY_FILE" \
        python3 <<'PY' 2>&1 >/dev/null
import os
import sys

try:
    from memory import MemoryStore
except Exception as e:
    print(f"import_failed: {e}")
    sys.exit(1)

try:
    store = MemoryStore(os.environ["JOI_MEMORY_DB"])
    # _init_schema() runs in constructor and recreates missing triggers.
    # Rebuild FTS index to resync after trigger-less deletes.
    conn = store._connect()  # internal helper is acceptable in admin recovery path
    try:
        conn.execute("INSERT INTO knowledge_fts(knowledge_fts) VALUES('rebuild')")
        conn.commit()
    except Exception:
        # If rebuild fails, triggers may still be restored; keep best-effort behavior.
        pass
except Exception as e:
    print(f"restore_failed: {e}")
    sys.exit(1)
PY
    ); then
        warn "Could not auto-restore knowledge FTS triggers/index via Python fallback."
        warn "Restart joi-api after installing an FTS5-capable sqlcipher to restore RAG indexing."
        if [[ -n "${py_err//[$'\t\r\n ']/}" ]]; then
            warn "Python restore error: $py_err"
        fi
        return 1
    fi

    info "  Restored knowledge FTS triggers/index via Python MemoryStore"
    return 0
}

# Purge messages and summaries
purge_contexts() {
    local conversation="$1"
    local count=0

    if [[ ! -f "$MEMORY_DB" ]]; then
        warn "Memory database not found: $MEMORY_DB"
        return
    fi

    if [[ -n "$conversation" ]]; then
        local conversation_escaped
        conversation_escaped=$(sql_escape_literal "$conversation")
        echo "Purging contexts for conversation: $conversation"
        count=$(db_scalar "SELECT COUNT(*) FROM messages WHERE conversation_id = '$conversation_escaped';")
        # Break self-referential reply chains before deleting parent rows.
        # Without this, SQLite can fail with FOREIGN KEY constraint errors.
        db_exec "UPDATE messages SET reply_to_id = NULL WHERE reply_to_id IN (SELECT message_id FROM messages WHERE conversation_id = '$conversation_escaped');"
        db_exec "DELETE FROM messages WHERE conversation_id = '$conversation_escaped';"
        db_exec "DELETE FROM context_summaries WHERE conversation_id = '$conversation_escaped';"
    else
        echo "Purging ALL contexts"
        count=$(db_scalar "SELECT COUNT(*) FROM messages;")
        # Clear reply links first to avoid FK failures on bulk delete.
        db_exec "UPDATE messages SET reply_to_id = NULL WHERE reply_to_id IS NOT NULL;"
        db_exec "DELETE FROM messages;"
        db_exec "DELETE FROM context_summaries;"
    fi

    info "  Deleted $count messages"
}

# Delete facts via Python so FTS5 triggers fire correctly.
# sqlcipher CLI has no FTS5 support; Python's sqlite3 does.
# JOI_FACTS_DELETE_MODE: "id", "conversation", or "all"
# JOI_FACTS_DELETE_VALUE: the id or conversation_id (unused for "all")
delete_facts_with_python() {
    local mode="$1"
    local value="${2:-}"

    if ! command -v python3 >/dev/null 2>&1; then
        error "python3 not available; cannot delete facts safely without FTS5 support."
    fi

    local py_err
    if ! py_err=$(PYTHONPATH="$JOI_PY_ROOT${PYTHONPATH:+:$PYTHONPATH}" \
        JOI_MEMORY_DB="$MEMORY_DB" \
        JOI_MEMORY_KEY_FILE="$MEMORY_KEY_FILE" \
        JOI_FACTS_DELETE_MODE="$mode" \
        JOI_FACTS_DELETE_VALUE="$value" \
        python3 <<'PY' 2>&1 >/dev/null
import os, sys
try:
    from memory import MemoryStore
except Exception as e:
    print(f"import_failed: {e}")
    sys.exit(1)
try:
    store = MemoryStore(os.environ["JOI_MEMORY_DB"])
    conn = store._connect()
    mode  = os.environ["JOI_FACTS_DELETE_MODE"]
    value = os.environ.get("JOI_FACTS_DELETE_VALUE", "")
    if mode == "id":
        conn.execute("DELETE FROM user_facts WHERE id = ?", (int(value),))
    elif mode == "conversation":
        conn.execute("DELETE FROM user_facts WHERE conversation_id = ?", (value,))
    elif mode == "all":
        conn.execute("DELETE FROM user_facts")
    else:
        print(f"unknown_mode: {mode}")
        sys.exit(1)
    conn.commit()
except Exception as e:
    print(f"delete_failed: {e}")
    sys.exit(1)
PY
    ); then
        error "Failed to delete facts via Python: ${py_err}"
    fi
}

# Add a fact via Python (uses store_fact() so FTS5 index stays in sync)
# Env vars: JOI_FACT_CONV, JOI_FACT_CAT, JOI_FACT_KEY, JOI_FACT_VAL, JOI_FACT_CONF
add_fact_with_python() {
    if ! command -v python3 >/dev/null 2>&1; then
        error "python3 not available; cannot add facts."
    fi

    local py_err py_out
    if ! py_out=$(PYTHONPATH="$JOI_PY_ROOT${PYTHONPATH:+:$PYTHONPATH}" \
        JOI_MEMORY_DB="$MEMORY_DB" \
        JOI_MEMORY_KEY_FILE="$MEMORY_KEY_FILE" \
        JOI_FACT_CONV="$JOI_FACT_CONV" \
        JOI_FACT_CAT="$JOI_FACT_CAT" \
        JOI_FACT_KEY="$JOI_FACT_KEY" \
        JOI_FACT_VAL="$JOI_FACT_VAL" \
        JOI_FACT_CONF="$JOI_FACT_CONF" \
        python3 <<'PY' 2>&1
import os, sys
try:
    from memory import MemoryStore
except Exception as e:
    print(f"import_failed: {e}", file=sys.stderr)
    sys.exit(1)
try:
    store = MemoryStore(os.environ["JOI_MEMORY_DB"])
    fact_id = store.store_fact(
        conversation_id=os.environ["JOI_FACT_CONV"],
        category=os.environ["JOI_FACT_CAT"],
        key=os.environ["JOI_FACT_KEY"],
        value=os.environ["JOI_FACT_VAL"],
        confidence=float(os.environ.get("JOI_FACT_CONF", "0.9")),
        source="admin",
    )
    print(fact_id)
except Exception as e:
    print(f"add_failed: {e}", file=sys.stderr)
    sys.exit(1)
PY
    ); then
        error "Failed to add fact: ${py_out}"
    fi
    echo "$py_out"
}

# Purge user facts
purge_facts() {
    local conversation="$1"
    local count=0

    if [[ ! -f "$MEMORY_DB" ]]; then
        warn "Memory database not found: $MEMORY_DB"
        return
    fi

    if [[ -n "$conversation" ]]; then
        local conversation_escaped
        conversation_escaped=$(sql_escape_literal "$conversation")
        echo "Purging facts for conversation: $conversation"
        count=$(db_scalar "SELECT COUNT(*) FROM user_facts WHERE conversation_id = '$conversation_escaped';")
        delete_facts_with_python "conversation" "$conversation"
    else
        echo "Purging ALL facts"
        count=$(db_scalar "SELECT COUNT(*) FROM user_facts;")
        delete_facts_with_python "all"
    fi

    info "  Deleted $count facts"
}

# Purge knowledge chunks
purge_knowledge() {
    local count=0

    if [[ ! -f "$MEMORY_DB" ]]; then
        warn "Memory database not found: $MEMORY_DB"
        return
    fi

    echo "Purging knowledge chunks"
    count=$(db_scalar "SELECT COUNT(*) FROM knowledge_chunks;")

    check_fts5_available

    if [[ "$_FTS5_AVAILABLE" == "no" ]]; then
        # CLI lacks FTS5: drop triggers first, delete, then restore via Python
        db_exec "DROP TRIGGER IF EXISTS knowledge_ai;"
        db_exec "DROP TRIGGER IF EXISTS knowledge_ad;"
        db_exec "DROP TRIGGER IF EXISTS knowledge_au;"
        db_exec "DELETE FROM knowledge_chunks;"
        restore_knowledge_fts_with_python || true
    else
        db_exec "DELETE FROM knowledge_chunks;"
        db_exec "DELETE FROM knowledge_fts;" >/dev/null 2>&1 || true
    fi

    info "  Deleted $count knowledge chunks"
}

# Purge nonce database
purge_nonces() {
    if [[ -f "$NONCE_DB" ]]; then
        echo "Purging nonce database"
        rm -f "$NONCE_DB"
        info "  Deleted $NONCE_DB"
    fi
}

# Regenerate HMAC key
regenerate_hmac() {
    echo "Regenerating HMAC key"

    local key_dir
    key_dir=$(dirname "$HMAC_KEY_FILE")

    if [[ ! -d "$key_dir" ]]; then
        mkdir -p "$key_dir"
        chown "$SERVICE_USER:$SERVICE_USER" "$key_dir"
        chmod 700 "$key_dir"
    fi

    # Generate new key
    local new_key
    new_key=$(openssl rand -hex 32)

    umask 077
    echo "$new_key" > "$HMAC_KEY_FILE"
    chmod 600 "$HMAC_KEY_FILE"
    chown "$SERVICE_USER:$SERVICE_USER" "$HMAC_KEY_FILE"

    # Also purge nonces since old signatures are invalid
    purge_nonces

    info "  New HMAC key written to $HMAC_KEY_FILE"
    warn "  Mesh VM must also update its HMAC key to match!"
}

# Remove Nebula host keys
purge_nebula_keys() {
    echo "Removing Nebula host keys"

    local removed=0
    for f in "$NEBULA_DIR"/host.key "$NEBULA_DIR"/host.crt; do
        if [[ -f "$f" ]]; then
            rm -f "$f"
            info "  Deleted $f"
            ((removed++))
        fi
    done

    if [[ $removed -eq 0 ]]; then
        warn "  No Nebula host keys found"
    else
        warn "  Host must be re-enrolled with Nebula CA"
    fi
}

# Remove Nebula CA (factory reset)
purge_nebula_ca() {
    echo "Removing Nebula CA certificate"

    if [[ -f "$NEBULA_DIR/ca.crt" ]]; then
        rm -f "$NEBULA_DIR/ca.crt"
        info "  Deleted $NEBULA_DIR/ca.crt"
        warn "  Complete Nebula re-setup required!"
    else
        warn "  No Nebula CA found"
    fi
}

# Reset system state
reset_system_state() {
    if [[ ! -f "$MEMORY_DB" ]]; then
        return
    fi

    echo "Resetting system state"
    db_exec "$(cat << 'SQL'
UPDATE system_state SET value = '0' WHERE key IN (
    'last_interaction_at',
    'last_impulse_check_at',
    'messages_sent_this_hour',
    'messages_sent_hour_start',
    'last_context_cleanup_at',
    'last_memory_consolidation_at'
);
UPDATE system_state SET value = '' WHERE key = 'current_conversation_topic';
UPDATE system_state SET value = '"idle"' WHERE key = 'agent_state';
SQL
)"
    info "  System state reset"
}

reset_autoincrement_counters() {
    if [[ ! -f "$MEMORY_DB" ]]; then
        return
    fi

    echo "Resetting AUTOINCREMENT counters"

    local non_empty_tables
    non_empty_tables=$(db_exec "$(cat << 'SQL'
SELECT table_name || ' (' || row_count || ' rows)'
FROM (
    SELECT 'messages' AS table_name, COUNT(*) AS row_count FROM messages
    UNION ALL
    SELECT 'user_facts', COUNT(*) FROM user_facts
    UNION ALL
    SELECT 'context_summaries', COUNT(*) FROM context_summaries
    UNION ALL
    SELECT 'knowledge_chunks', COUNT(*) FROM knowledge_chunks
) t
WHERE row_count > 0
ORDER BY table_name;
SQL
)" | awk 'NF && $0 != "ok"')

    if [[ -n "${non_empty_tables//[$'\t\r\n ']/}" ]]; then
        error "--reset-counters requires empty memory tables, found data in: $non_empty_tables"
    fi

    db_exec "DELETE FROM sqlite_sequence WHERE name IN ('messages','user_facts','context_summaries','knowledge_chunks');"
    info "  AUTOINCREMENT counters reset"
}

vacuum_memory_db() {
    if [[ ! -f "$MEMORY_DB" ]]; then
        warn "Memory database not found: $MEMORY_DB"
        return
    fi

    echo "Running VACUUM on memory database"
    db_exec "VACUUM;"
    info "  Memory database compacted"
}

rag_delete_chunks() {
    local source="$1"
    local scope="${2:-}"
    local delete_err=""

    check_fts5_available

    if [[ "$_FTS5_AVAILABLE" == "no" ]]; then
        db_exec "DROP TRIGGER IF EXISTS knowledge_ai;"
        db_exec "DROP TRIGGER IF EXISTS knowledge_ad;"
        db_exec "DROP TRIGGER IF EXISTS knowledge_au;"
    fi

    if [[ -n "$scope" ]]; then
        local source_escaped scope_escaped
        source_escaped=$(sql_escape_literal "$source")
        scope_escaped=$(sql_escape_literal "$scope")
        if ! delete_err=$(db_exec "DELETE FROM knowledge_chunks WHERE source = '$source_escaped' AND scope = '$scope_escaped';" 2>&1); then
            printf "%s\n" "$delete_err" >&2
            error "Failed to delete RAG source"
        fi
    else
        local source_escaped
        source_escaped=$(sql_escape_literal "$source")
        if ! delete_err=$(db_exec "DELETE FROM knowledge_chunks WHERE source = '$source_escaped';" 2>&1); then
            printf "%s\n" "$delete_err" >&2
            error "Failed to delete RAG source"
        fi
    fi

    if [[ "$_FTS5_AVAILABLE" == "no" ]]; then
        restore_knowledge_fts_with_python || true
    fi
}

cmd_rag() {
    if [[ ! -f "$MEMORY_DB" ]]; then
        error "Memory database not found: $MEMORY_DB"
    fi

    local subcommand="${1:-}"
    [[ -z "$subcommand" ]] && error "Usage: joi-admin rag <list|show|scopes|stats|delete|rescope|orphans> [OPTIONS]"
    shift || true

    case "$subcommand" in
        list)
            local scope_filter=""
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --scope)
                        [[ -z "${2:-}" ]] && error "--scope requires a value"
                        scope_filter="$2"
                        shift 2
                        ;;
                    --help|-h)
                        echo "Usage: joi-admin rag list [--scope SCOPE]"
                        exit 0
                        ;;
                    *)
                        error "Unknown option for 'rag list': $1"
                        ;;
                esac
            done

            local where_clause=""
            if [[ -n "$scope_filter" ]]; then
                local scope_escaped
                scope_escaped=$(sql_escape_literal "$scope_filter")
                where_clause="WHERE scope = '$scope_escaped'"
            fi

            local rows
            rows=$(db_exec "$(cat <<SQL
SELECT COALESCE(scope, ''), source, COUNT(*), COALESCE(MAX(created_at), 0)
FROM knowledge_chunks
$where_clause
GROUP BY scope, source
ORDER BY scope, source;
SQL
)" | awk 'NF && $0 != "ok"')

            if [[ -z "${rows//[$'\t\r\n ']/}" ]]; then
                echo "No knowledge sources found."
                exit 0
            fi

            printf "%-40s  %-60s  %8s  %s\n" "scope" "source" "chunks" "last_updated"
            printf "%-40s  %-60s  %8s  %s\n" "-----" "------" "------" "-----------"
            while IFS='|' read -r scope source chunks last_updated; do
                [[ -z "${scope}${source}${chunks}${last_updated}" ]] && continue
                [[ -z "$scope" ]] && scope="(no scope)"
                printf "%-40s  %-60s  %8s  %s\n" "$scope" "$source" "$chunks" "$last_updated"
            done <<< "$rows"
            ;;

        show)
            local chunk_id=""
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --id)
                        [[ -z "${2:-}" ]] && error "--id requires a value"
                        [[ ! "$2" =~ ^[0-9]+$ ]] && error "--id must be a positive integer"
                        chunk_id="$2"; shift 2 ;;
                    --help|-h)
                        echo "Usage: joi-admin rag show --id ID"
                        echo ""
                        echo "Show all fields for a single knowledge chunk."
                        exit 0 ;;
                    *) error "Unknown option for 'rag show': $1" ;;
                esac
            done
            [[ -z "$chunk_id" ]] && error "rag show requires --id ID"

            local exists
            exists=$(db_scalar "SELECT COUNT(*) FROM knowledge_chunks WHERE id = $chunk_id;")
            [[ "${exists:-0}" == "0" ]] && error "No knowledge chunk found with id $chunk_id"

            echo ""
            echo "=== KNOWLEDGE CHUNK #$chunk_id ==="
            printf "  %-18s %s\n" "id:" "$(db_scalar "SELECT id FROM knowledge_chunks WHERE id = $chunk_id;")"
            printf "  %-18s %s\n" "scope:" "$(db_scalar "SELECT COALESCE(scope,'(none)') FROM knowledge_chunks WHERE id = $chunk_id;")"
            printf "  %-18s %s\n" "source:" "$(db_scalar "SELECT COALESCE(source,'') FROM knowledge_chunks WHERE id = $chunk_id;")"
            printf "  %-18s %s\n" "title:" "$(db_scalar "SELECT COALESCE(title,'') FROM knowledge_chunks WHERE id = $chunk_id;")"
            printf "  %-18s %s\n" "chunk_index:" "$(db_scalar "SELECT COALESCE(chunk_index,0) FROM knowledge_chunks WHERE id = $chunk_id;")"
            printf "  %-18s %s\n" "created_at:" "$(db_scalar "SELECT datetime(created_at/1000,'unixepoch') FROM knowledge_chunks WHERE id = $chunk_id;")"
            printf "  %-18s %s\n" "metadata_json:" "$(db_scalar "SELECT COALESCE(metadata_json,'-') FROM knowledge_chunks WHERE id = $chunk_id;")"
            local content
            content=$(db_scalar "SELECT COALESCE(content,'') FROM knowledge_chunks WHERE id = $chunk_id;")
            if [[ -n "$content" ]]; then
                echo ""
                echo "  --- content ---"
                echo "$content" | fold -s -w 72 | sed 's/^/  /'
            fi
            echo ""
            ;;

        scopes)
            [[ $# -gt 0 ]] && [[ "$1" != "--help" ]] && [[ "$1" != "-h" ]] && error "Usage: joi-admin rag scopes"
            local rows
            rows=$(db_exec "$(cat <<'SQL'
SELECT COALESCE(scope, ''), COUNT(DISTINCT source), COUNT(*), COALESCE(MAX(created_at), 0)
FROM knowledge_chunks
GROUP BY scope
ORDER BY scope;
SQL
)" | awk 'NF && $0 != "ok"')

            if [[ -z "${rows//[$'\t\r\n ']/}" ]]; then
                echo "No knowledge scopes found."
                exit 0
            fi

            printf "%-40s  %8s  %8s  %s\n" "scope" "sources" "chunks" "last_updated"
            printf "%-40s  %8s  %8s  %s\n" "-----" "-------" "------" "-----------"
            while IFS='|' read -r scope source_count chunk_count last_updated; do
                [[ -z "${scope}${source_count}${chunk_count}${last_updated}" ]] && continue
                [[ -z "$scope" ]] && scope="(no scope)"
                printf "%-40s  %8s  %8s  %s\n" "$scope" "$source_count" "$chunk_count" "$last_updated"
            done <<< "$rows"
            ;;

        stats)
            [[ $# -gt 0 ]] && [[ "$1" != "--help" ]] && [[ "$1" != "-h" ]] && error "Usage: joi-admin rag stats"
            local stats
            stats=$(db_exec "$(cat <<'SQL'
SELECT
  COUNT(DISTINCT COALESCE(scope, '')) AS scope_count,
  COUNT(DISTINCT COALESCE(scope, '') || CHAR(31) || source) AS source_count,
  COUNT(*) AS chunk_count
FROM knowledge_chunks;
SQL
)" | awk 'NF && $0 != "ok" { print; exit }')

            local scope_count source_count chunk_count
            IFS='|' read -r scope_count source_count chunk_count <<< "$stats"
            echo "RAG statistics"
            echo "  Scopes:  ${scope_count:-0}"
            echo "  Sources: ${source_count:-0}"
            echo "  Chunks:  ${chunk_count:-0}"
            ;;

        delete)
            local source=""
            local scope=""
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --source)
                        [[ -z "${2:-}" ]] && error "--source requires a value"
                        source="$2"
                        shift 2
                        ;;
                    --scope)
                        [[ -z "${2:-}" ]] && error "--scope requires a value"
                        scope="$2"
                        shift 2
                        ;;
                    --help|-h)
                        echo "Usage: joi-admin rag delete --source SOURCE [--scope SCOPE]"
                        exit 0
                        ;;
                    *)
                        error "Unknown option for 'rag delete': $1"
                        ;;
                esac
            done
            [[ -z "$source" ]] && error "rag delete requires --source"

            local source_escaped count
            source_escaped=$(sql_escape_literal "$source")
            if [[ -n "$scope" ]]; then
                local scope_escaped
                scope_escaped=$(sql_escape_literal "$scope")
                count=$(db_scalar "SELECT COUNT(*) FROM knowledge_chunks WHERE source = '$source_escaped' AND scope = '$scope_escaped';")
            else
                count=$(db_scalar "SELECT COUNT(*) FROM knowledge_chunks WHERE source = '$source_escaped';")
            fi

            if [[ "${count:-0}" == "0" ]]; then
                echo "No RAG chunks found for source '$source'${scope:+ (scope: $scope)}."
                exit 0
            fi

            echo ""
            echo "=== RAG DELETE SUMMARY ==="
            echo "  Source: $source"
            [[ -n "$scope" ]] && echo "  Scope:  $scope" || echo "  Scope:  ALL matching scopes"
            echo "  Chunks: $count"
            echo ""

            read -p "Delete these RAG chunks? [y/N] " -n 1 -r
            echo
            if [[ ! $REPLY =~ ^[Yy]$ ]]; then
                echo "Aborted."
                exit 1
            fi

            rag_delete_chunks "$source" "$scope"
            info "Deleted $count RAG chunks"
            ;;

        rescope)
            local from_scope=""
            local to_scope=""
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --from)
                        [[ -z "${2:-}" ]] && error "--from requires a value"
                        from_scope="$2"
                        shift 2
                        ;;
                    --to)
                        [[ -z "${2:-}" ]] && error "--to requires a value"
                        to_scope="$2"
                        shift 2
                        ;;
                    --help|-h)
                        echo "Usage: joi-admin rag rescope --from OLD_SCOPE --to NEW_SCOPE"
                        exit 0
                        ;;
                    *)
                        error "Unknown option for 'rag rescope': $1"
                        ;;
                esac
            done
            [[ -z "$from_scope" || -z "$to_scope" ]] && error "rag rescope requires --from and --to"

            local from_escaped chunk_count source_count
            from_escaped=$(sql_escape_literal "$from_scope")
            chunk_count=$(db_scalar "SELECT COUNT(*) FROM knowledge_chunks WHERE scope = '$from_escaped';")
            source_count=$(db_scalar "SELECT COUNT(DISTINCT source) FROM knowledge_chunks WHERE scope = '$from_escaped';")

            if [[ "${chunk_count:-0}" == "0" ]]; then
                echo "No RAG chunks found in scope '$from_scope'."
                exit 0
            fi

            echo ""
            echo "=== RAG RESCOPE SUMMARY ==="
            echo "  From scope: $from_scope"
            echo "  To scope:   $to_scope"
            echo "  Sources:    $source_count"
            echo "  Chunks:     $chunk_count"
            echo ""

            read -p "Rescope these RAG chunks? [y/N] " -n 1 -r
            echo
            if [[ ! $REPLY =~ ^[Yy]$ ]]; then
                echo "Aborted."
                exit 1
            fi

            local from_sql to_sql
            from_sql=$(sql_escape_literal "$from_scope")
            to_sql=$(sql_escape_literal "$to_scope")
            db_exec "UPDATE knowledge_chunks SET scope = '$to_sql' WHERE scope = '$from_sql';"
            info "Rescoped $chunk_count chunks: '$from_scope' -> '$to_scope'"
            ;;

        orphans)
            local do_clean=false
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --clean)
                        do_clean=true
                        shift
                        ;;
                    --help|-h)
                        echo "Usage: joi-admin rag orphans [--clean]"
                        echo "Check for orphaned knowledge chunks (empty or NULL scope)."
                        echo "These chunks are inaccessible since the system filters by scope."
                        echo ""
                        echo "Options:"
                        echo "  --clean    Delete orphaned chunks (requires confirmation)"
                        exit 0
                        ;;
                    *)
                        error "Unknown option for 'rag orphans': $1"
                        ;;
                esac
            done

            local orphan_count source_list
            orphan_count=$(db_scalar "SELECT COUNT(*) FROM knowledge_chunks WHERE scope = '' OR scope IS NULL;")

            if [[ "${orphan_count:-0}" == "0" ]]; then
                info "No orphaned knowledge chunks found."
                exit 0
            fi

            source_list=$(db_exec "SELECT DISTINCT source FROM knowledge_chunks WHERE scope = '' OR scope IS NULL;" | awk 'NF && $0 != "ok"')

            echo "Orphaned knowledge chunks (empty/NULL scope)"
            echo "============================================"
            echo "  Count:   $orphan_count"
            echo "  Sources:"
            while IFS= read -r src; do
                [[ -z "$src" ]] && continue
                echo "    - $src"
            done <<< "$source_list"
            echo ""

            if ! $do_clean; then
                warn "These chunks are inaccessible. Run with --clean to delete them."
                exit 0
            fi

            read -p "Delete $orphan_count orphaned chunks? [y/N] " -n 1 -r
            echo
            if [[ ! $REPLY =~ ^[Yy]$ ]]; then
                echo "Aborted."
                exit 1
            fi

            db_exec "DELETE FROM knowledge_chunks WHERE scope = '' OR scope IS NULL;"
            info "Deleted $orphan_count orphaned chunks."
            ;;

        --help|-h)
            cat <<'HELP'
Usage: joi-admin rag <subcommand> [OPTIONS]

Subcommands:
  list     [--scope SCOPE]                    List knowledge sources (grouped)
  show     --id ID                            Show full content of a single chunk
  scopes                                      List all scopes with chunk counts
  stats                                       Overall RAG statistics
  delete   --source SOURCE [--scope SCOPE]    Delete all chunks for a source
  rescope  --from OLD_SCOPE --to NEW_SCOPE    Move chunks to a different scope
  orphans                                     Find/fix chunks with no scope

Examples:
  joi-admin rag list
  joi-admin rag show --id 42
  joi-admin rag delete --source 'diary.txt' --scope +1234567890
HELP
            exit 0
            ;;

        *)
            error "Unknown rag subcommand: $subcommand"
            ;;
    esac
}

cmd_summaries() {
    if [[ ! -f "$MEMORY_DB" ]]; then
        error "Memory database not found: $MEMORY_DB"
    fi

    local subcommand="${1:-}"
    [[ -z "$subcommand" ]] && error "Usage: joi-admin summaries <list|show|delete> [OPTIONS]"
    shift || true

    case "$subcommand" in
        list)
            local conversation=""
            local limit="50"

            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --conversation)
                        [[ -z "${2:-}" ]] && error "--conversation requires an ID"
                        conversation="$2"
                        shift 2
                        ;;
                    --limit)
                        [[ -z "${2:-}" ]] && error "--limit requires a number"
                        [[ ! "$2" =~ ^[0-9]+$ ]] && error "--limit must be a positive integer"
                        limit="$2"
                        shift 2
                        ;;
                    --help|-h)
                        echo "Usage: joi-admin summaries list [--conversation ID] [--limit N]"
                        exit 0
                        ;;
                    *)
                        error "Unknown option for 'summaries list': $1"
                        ;;
                esac
            done

            local where_clause=""
            if [[ -n "$conversation" ]]; then
                local conversation_escaped
                conversation_escaped=$(sql_escape_literal "$conversation")
                where_clause="WHERE conversation_id = '$conversation_escaped'"
            fi

            local rows
            rows=$(db_exec "$(cat <<SQL
SELECT
    id,
    COALESCE(conversation_id, ''),
    COALESCE(summary_type, ''),
    COALESCE(period_start, 0),
    COALESCE(period_end, 0),
    COALESCE(message_count, 0),
    COALESCE(created_at, 0),
    substr(replace(replace(COALESCE(summary_text, ''), char(10), ' '), char(13), ' '), 1, 100)
FROM context_summaries
$where_clause
ORDER BY created_at DESC, id DESC
LIMIT $limit;
SQL
)" | awk 'NF && $0 != "ok"')

            if [[ -z "${rows//[$'\t\r\n ']/}" ]]; then
                echo "No context summaries found${conversation:+ for conversation '$conversation'}."
                exit 0
            fi

            printf "%6s  %-28s  %-12s  %8s  %13s  %13s  %-s\n" \
                "id" "conversation_id" "type" "msgs" "created_at" "period" "preview"
            printf "%6s  %-28s  %-12s  %8s  %13s  %13s  %-s\n" \
                "--" "---------------" "----" "----" "----------" "------" "-------"

            while IFS='|' read -r sid convo stype pstart pend mcount created preview; do
                [[ -z "${sid}${convo}${stype}${pstart}${pend}${mcount}${created}${preview}" ]] && continue
                [[ -z "$convo" ]] && convo="(none)"
                local period="${pstart}-${pend}"
                printf "%6s  %-28s  %-12s  %8s  %13s  %13s  %s\n" \
                    "$sid" "$convo" "$stype" "$mcount" "$created" "$period" "$preview"
            done <<< "$rows"
            ;;
        show)
            local summary_id=""
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --id)
                        [[ -z "${2:-}" ]] && error "--id requires a value"
                        [[ ! "$2" =~ ^[0-9]+$ ]] && error "--id must be a positive integer"
                        summary_id="$2"
                        shift 2
                        ;;
                    --help|-h)
                        echo "Usage: joi-admin summaries show --id ID"
                        exit 0
                        ;;
                    *)
                        error "Unknown option for 'summaries show': $1"
                        ;;
                esac
            done
            [[ -z "$summary_id" ]] && error "summaries show requires --id"

            local meta_row
            meta_row=$(db_exec "$(cat <<SQL
SELECT
    id,
    COALESCE(conversation_id, ''),
    COALESCE(summary_type, ''),
    COALESCE(period_start, 0),
    COALESCE(period_end, 0),
    COALESCE(message_count, 0),
    COALESCE(created_at, 0)
FROM context_summaries
WHERE id = $summary_id
LIMIT 1;
SQL
)" | awk 'NF && $0 != "ok"')

            if [[ -z "${meta_row//[$'\t\r\n ']/}" ]]; then
                echo "No context summary found with id=$summary_id."
                exit 0
            fi

            local text_hex text
            text_hex=$(db_exec "SELECT hex(COALESCE(summary_text, '')) FROM context_summaries WHERE id = $summary_id LIMIT 1;" | awk 'NF && $0 != "ok" { print; exit }')
            if [[ -n "$text_hex" ]]; then
                text=$(printf "%s" "$text_hex" | python3 -c 'import sys; h=sys.stdin.read().strip(); print(bytes.fromhex(h).decode("utf-8", errors="replace"), end="")')
            else
                text=""
            fi

            local sid convo stype pstart pend mcount created
            IFS='|' read -r sid convo stype pstart pend mcount created <<< "$meta_row"
            [[ -z "$convo" ]] && convo="(none)"

            echo "=== SUMMARY $sid ==="
            echo "conversation_id: $convo"
            echo "summary_type:    $stype"
            echo "message_count:   $mcount"
            echo "period_start:    $pstart"
            echo "period_end:      $pend"
            echo "created_at:      $created"
            echo ""
            echo "summary_text:"
            printf "%s\n" "$text"
            ;;
        delete)
            local summary_id=""
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --id)
                        [[ -z "${2:-}" ]] && error "--id requires a value"
                        [[ ! "$2" =~ ^[0-9]+$ ]] && error "--id must be a positive integer"
                        summary_id="$2"
                        shift 2
                        ;;
                    --help|-h)
                        echo "Usage: joi-admin summaries delete --id ID"
                        exit 0
                        ;;
                    *)
                        error "Unknown option for 'summaries delete': $1"
                        ;;
                esac
            done
            [[ -z "$summary_id" ]] && error "summaries delete requires --id"

            local meta_row preview
            meta_row=$(db_exec "$(cat <<SQL
SELECT
    id,
    COALESCE(conversation_id, ''),
    COALESCE(summary_type, ''),
    COALESCE(message_count, 0),
    COALESCE(created_at, 0),
    COALESCE(period_start, 0),
    COALESCE(period_end, 0)
FROM context_summaries
WHERE id = $summary_id
LIMIT 1;
SQL
)" | awk 'NF && $0 != "ok"')

            if [[ -z "${meta_row//[$'\t\r\n ']/}" ]]; then
                echo "No context summary found with id=$summary_id."
                exit 0
            fi

            preview=$(db_exec "SELECT substr(replace(replace(COALESCE(summary_text, ''), char(10), ' '), char(13), ' '), 1, 120) FROM context_summaries WHERE id = $summary_id LIMIT 1;" | awk 'NF && $0 != "ok" { print; exit }')

            local sid convo stype mcount created pstart pend
            IFS='|' read -r sid convo stype mcount created pstart pend <<< "$meta_row"
            [[ -z "$convo" ]] && convo="(none)"

            echo ""
            echo "=== SUMMARY DELETE SUMMARY ==="
            echo "  id:             $sid"
            echo "  conversation_id:$convo"
            echo "  summary_type:   $stype"
            echo "  message_count:  $mcount"
            echo "  created_at:     $created"
            echo "  period:         $pstart-$pend"
            if [[ -n "$preview" ]]; then
                echo "  preview:        $preview"
            fi
            echo ""

            read -p "Delete this summary? [y/N] " -n 1 -r
            echo
            if [[ ! $REPLY =~ ^[Yy]$ ]]; then
                echo "Aborted."
                exit 1
            fi

            db_exec "DELETE FROM context_summaries WHERE id = $summary_id;"
            info "Deleted summary id=$summary_id"
            ;;
        --help|-h)
            echo "Usage: joi-admin summaries <list|show|delete> [OPTIONS]"
            exit 0
            ;;
        *)
            error "Unknown summaries subcommand: $subcommand"
            ;;
    esac
}

cmd_fts() {
    if [[ ! -f "$MEMORY_DB" ]]; then
        error "Memory database not found: $MEMORY_DB"
    fi

    local subcommand="${1:-}"
    [[ -z "$subcommand" ]] && error "Usage: joi-admin fts <status|rebuild> [OPTIONS]"
    shift || true

    case "$subcommand" in
        status)
            echo "FTS Index Integrity Check"
            echo "========================="
            echo ""

            local all_ok=true

            # Check knowledge_fts
            local knowledge_fts_count knowledge_main_count
            knowledge_fts_count=$(db_scalar "SELECT COUNT(*) FROM knowledge_fts;" 2>/dev/null || echo "error")
            knowledge_main_count=$(db_scalar "SELECT COUNT(*) FROM knowledge_chunks;" 2>/dev/null || echo "error")

            if [[ "$knowledge_fts_count" == "error" ]]; then
                echo "knowledge_fts:   ERROR (table may not exist)"
                all_ok=false
            elif [[ "$knowledge_fts_count" == "$knowledge_main_count" ]]; then
                info "knowledge_fts:   OK ($knowledge_fts_count rows)"
            else
                warn "knowledge_fts:   OUT OF SYNC (FTS=$knowledge_fts_count, main=$knowledge_main_count)"
                all_ok=false
            fi

            # Check user_facts_fts
            local facts_fts_count facts_main_count
            facts_fts_count=$(db_scalar "SELECT COUNT(*) FROM user_facts_fts;" 2>/dev/null || echo "error")
            facts_main_count=$(db_scalar "SELECT COUNT(*) FROM user_facts WHERE active = 1;" 2>/dev/null || echo "error")

            if [[ "$facts_fts_count" == "error" ]]; then
                echo "user_facts_fts:  ERROR (table may not exist)"
                all_ok=false
            elif [[ "$facts_fts_count" == "$facts_main_count" ]]; then
                info "user_facts_fts:  OK ($facts_fts_count rows)"
            else
                warn "user_facts_fts:  OUT OF SYNC (FTS=$facts_fts_count, main=$facts_main_count)"
                all_ok=false
            fi

            # Check summaries_fts
            local summaries_fts_count summaries_main_count
            summaries_fts_count=$(db_scalar "SELECT COUNT(*) FROM summaries_fts;" 2>/dev/null || echo "error")
            summaries_main_count=$(db_scalar "SELECT COUNT(*) FROM context_summaries;" 2>/dev/null || echo "error")

            if [[ "$summaries_fts_count" == "error" ]]; then
                echo "summaries_fts:   ERROR (table may not exist)"
                all_ok=false
            elif [[ "$summaries_fts_count" == "$summaries_main_count" ]]; then
                info "summaries_fts:   OK ($summaries_fts_count rows)"
            else
                warn "summaries_fts:   OUT OF SYNC (FTS=$summaries_fts_count, main=$summaries_main_count)"
                all_ok=false
            fi

            echo ""
            if $all_ok; then
                info "All FTS indexes are in sync."
            else
                warn "Some FTS indexes need attention. Run 'joi-admin fts rebuild' to repair."
            fi
            ;;

        rebuild)
            local index_name=""
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --index)
                        [[ -z "${2:-}" ]] && error "--index requires a value"
                        index_name="$2"
                        shift 2
                        ;;
                    --help|-h)
                        echo "Usage: joi-admin fts rebuild [--index NAME]"
                        echo "Indexes: knowledge_fts, user_facts_fts, summaries_fts"
                        exit 0
                        ;;
                    *)
                        error "Unknown option for 'fts rebuild': $1"
                        ;;
                esac
            done

            local indexes_to_rebuild=()
            if [[ -n "$index_name" ]]; then
                case "$index_name" in
                    knowledge_fts|user_facts_fts|summaries_fts)
                        indexes_to_rebuild+=("$index_name")
                        ;;
                    *)
                        error "Unknown index: $index_name. Valid: knowledge_fts, user_facts_fts, summaries_fts"
                        ;;
                esac
            else
                indexes_to_rebuild=("knowledge_fts" "user_facts_fts" "summaries_fts")
            fi

            echo "Rebuilding FTS indexes: ${indexes_to_rebuild[*]}"
            echo ""

            for idx in "${indexes_to_rebuild[@]}"; do
                echo -n "Rebuilding $idx... "
                if db_exec "INSERT INTO ${idx}(${idx}) VALUES('rebuild');" 2>/dev/null; then
                    info "OK"
                else
                    warn "FAILED (FTS5 module may not be available)"
                fi
            done

            echo ""
            info "FTS rebuild complete. Run 'joi-admin fts status' to verify."
            ;;

        --help|-h)
            echo "Usage: joi-admin fts <status|rebuild> [OPTIONS]"
            exit 0
            ;;

        *)
            error "Unknown fts subcommand: $subcommand"
            ;;
    esac
}

# Wind command for WindMood management
cmd_wind() {
    if [[ ! -f "$MEMORY_DB" ]]; then
        error "Memory database not found: $MEMORY_DB"
    fi

    local subcommand="${1:-}"
    [[ -z "$subcommand" ]] && error "Usage: joi-admin wind <subcommand> [OPTIONS] -- use 'joi-admin wind --help' for subcommands"
    shift || true

    case "$subcommand" in
        show-windmood)
            [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]] && { echo "Usage: joi-admin wind show-windmood [conversation_id]"; exit 0; }
            local conversation="${1:-}"

            local where_clause=""
            if [[ -n "$conversation" ]]; then
                local conversation_escaped
                conversation_escaped=$(sql_escape_literal "$conversation")
                where_clause="WHERE conversation_id = '$conversation_escaped'"
            fi

            local rows
            rows=$(db_exec "$(cat <<SQL
SELECT
    conversation_id,
    COALESCE(threshold_offset, 'NULL'),
    COALESCE(accumulated_impulse, 0.0),
    COALESCE(updated_at, '')
FROM wind_state
$where_clause
ORDER BY conversation_id;
SQL
)" | awk 'NF && $0 != "ok"')

            if [[ -z "${rows//[$'\t\r\n ']/}" ]]; then
                echo "No WindMood state found${conversation:+ for conversation '$conversation'}."
                exit 0
            fi

            printf "%-40s  %12s  %12s  %s\n" "conversation_id" "offset" "accumulated" "updated_at"
            printf "%-40s  %12s  %12s  %s\n" "---------------" "------" "-----------" "----------"
            while IFS='|' read -r conv_id offset accum updated; do
                [[ -z "${conv_id}${offset}${accum}${updated}" ]] && continue
                printf "%-40s  %12s  %12.2f  %s\n" "$conv_id" "$offset" "$accum" "$updated"
            done <<< "$rows"
            ;;

        reset-windmood)
            [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]] && { echo "Usage: joi-admin wind reset-windmood [conversation_id]"; exit 0; }
            local conversation="${1:-}"

            local count
            if [[ -n "$conversation" ]]; then
                local conversation_escaped
                conversation_escaped=$(sql_escape_literal "$conversation")
                count=$(db_scalar "SELECT COUNT(*) FROM wind_state WHERE conversation_id = '$conversation_escaped';")
            else
                count=$(db_scalar "SELECT COUNT(*) FROM wind_state;")
            fi

            if [[ "${count:-0}" == "0" ]]; then
                echo "No WindMood state found${conversation:+ for conversation '$conversation'}."
                exit 0
            fi

            echo ""
            echo "=== WINDMOOD RESET SUMMARY ==="
            [[ -n "$conversation" ]] && echo "  Conversation: $conversation" || echo "  Scope: ALL conversations"
            echo "  Affected: $count"
            echo "  Action: Set threshold_offset=NULL, accumulated_impulse=0"
            echo ""

            read -p "Reset WindMood state? [y/N] " -n 1 -r
            echo
            if [[ ! $REPLY =~ ^[Yy]$ ]]; then
                echo "Aborted."
                exit 1
            fi

            local now
            now=$(date -Iseconds)
            if [[ -n "$conversation" ]]; then
                db_exec "UPDATE wind_state SET threshold_offset = NULL, accumulated_impulse = 0.0, updated_at = '$now' WHERE conversation_id = '$conversation_escaped';"
            else
                db_exec "UPDATE wind_state SET threshold_offset = NULL, accumulated_impulse = 0.0, updated_at = '$now';"
            fi

            info "Reset WindMood for $count conversation(s)"
            ;;

        set-windmood)
            local conversation="${1:-}"
            [[ -z "$conversation" ]] && error "set-windmood requires a conversation_id"
            shift || true

            local offset=""
            local accumulated=""

            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --offset)
                        [[ -z "${2:-}" ]] && error "--offset requires a value"
                        offset="$2"
                        shift 2
                        ;;
                    --accumulated)
                        [[ -z "${2:-}" ]] && error "--accumulated requires a value"
                        accumulated="$2"
                        shift 2
                        ;;
                    --help|-h)
                        echo "Usage: joi-admin wind set-windmood <conversation_id> [--offset VALUE] [--accumulated VALUE]"
                        exit 0
                        ;;
                    *)
                        error "Unknown option for 'wind set-windmood': $1"
                        ;;
                esac
            done

            if [[ -z "$offset" && -z "$accumulated" ]]; then
                error "set-windmood requires at least --offset or --accumulated"
            fi

            # Validate offset range
            if [[ -n "$offset" ]]; then
                if ! [[ "$offset" =~ ^-?[0-9]*\.?[0-9]+$ ]]; then
                    error "--offset must be a number (e.g., 0.05, -0.03)"
                fi
                local offset_check
                offset_check=$(echo "$offset" | awk '{ if ($1 < -0.1 || $1 > 0.1) print "bad" }')
                if [[ "$offset_check" == "bad" ]]; then
                    error "--offset must be between -0.1 and 0.1"
                fi
            fi

            # Validate accumulated range
            if [[ -n "$accumulated" ]]; then
                if ! [[ "$accumulated" =~ ^[0-9]*\.?[0-9]+$ ]]; then
                    error "--accumulated must be a non-negative number"
                fi
            fi

            local conversation_escaped
            conversation_escaped=$(sql_escape_literal "$conversation")

            # Check if conversation exists
            local exists
            exists=$(db_scalar "SELECT COUNT(*) FROM wind_state WHERE conversation_id = '$conversation_escaped';")
            if [[ "${exists:-0}" == "0" ]]; then
                error "No WindMood state found for conversation '$conversation'"
            fi

            # Build update
            local set_parts=()
            local now
            now=$(date -Iseconds)
            [[ -n "$offset" ]] && set_parts+=("threshold_offset = $offset")
            [[ -n "$accumulated" ]] && set_parts+=("accumulated_impulse = $accumulated")
            set_parts+=("updated_at = '$now'")

            local set_clause
            set_clause=$(IFS=', '; echo "${set_parts[*]}")

            db_exec "UPDATE wind_state SET $set_clause WHERE conversation_id = '$conversation_escaped';"

            info "Updated WindMood for '$conversation'"
            [[ -n "$offset" ]] && echo "  threshold_offset = $offset"
            [[ -n "$accumulated" ]] && echo "  accumulated_impulse = $accumulated"
            ;;

        show-engagement)
            [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]] && { echo "Usage: joi-admin wind show-engagement [conversation_id]"; exit 0; }
            local conversation="${1:-}"

            local where_clause=""
            if [[ -n "$conversation" ]]; then
                local conversation_escaped
                conversation_escaped=$(sql_escape_literal "$conversation")
                where_clause="WHERE conversation_id = '$conversation_escaped'"
            fi

            local rows
            rows=$(db_exec "$(cat <<SQL
SELECT
    conversation_id,
    COALESCE(engagement_score, 0.5),
    COALESCE(total_proactives_sent, 0),
    COALESCE(total_engaged, 0),
    COALESCE(total_ignored, 0),
    COALESCE(total_deflected, 0),
    COALESCE(last_engaged_at, ''),
    COALESCE(last_deflected_at, '')
FROM wind_state
$where_clause
ORDER BY conversation_id;
SQL
)" | awk 'NF && $0 != "ok"')

            if [[ -z "${rows//[$'\t\r\n ']/}" ]]; then
                echo "No engagement stats found${conversation:+ for conversation '$conversation'}."
                exit 0
            fi

            printf "%-28s  %8s  %6s  %6s  %6s  %6s  %s\n" \
                "conversation_id" "score" "sent" "engd" "ignrd" "deflc" "last_engaged"
            printf "%-28s  %8s  %6s  %6s  %6s  %6s  %s\n" \
                "---------------" "-----" "----" "----" "-----" "-----" "------------"
            while IFS='|' read -r conv_id score sent engaged ignored deflected last_eng last_def; do
                [[ -z "${conv_id}${score}" ]] && continue
                printf "%-28s  %8.3f  %6d  %6d  %6d  %6d  %s\n" \
                    "$conv_id" "$score" "$sent" "$engaged" "$ignored" "$deflected" "$last_eng"
            done <<< "$rows"
            ;;

        show-feedback)
            [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]] && { echo "Usage: joi-admin wind show-feedback <conversation_id>"; exit 0; }
            local conversation="${1:-}"
            [[ -z "$conversation" ]] && error "show-feedback requires a conversation_id"

            local conversation_escaped
            conversation_escaped=$(sql_escape_literal "$conversation")

            local rows
            rows=$(db_exec "$(cat <<SQL
SELECT
    topic_family,
    COALESCE(rejection_weight, 0.0),
    COALESCE(interest_weight, 0.0),
    COALESCE(engagement_count, 0),
    COALESCE(ignore_count, 0),
    COALESCE(deflection_count, 0),
    COALESCE(cooldown_until, ''),
    COALESCE(undertaker, 0),
    COALESCE(updated_at, '')
FROM topic_feedback
WHERE conversation_id = '$conversation_escaped'
ORDER BY topic_family;
SQL
)" | awk 'NF && $0 != "ok"')

            if [[ -z "${rows//[$'\t\r\n ']/}" ]]; then
                echo "No topic feedback found for conversation '$conversation'."
                exit 0
            fi

            echo "Topic feedback for: $conversation"
            echo ""
            printf "%-20s  %8s  %8s  %6s  %6s  %6s  %-10s  %s\n" \
                "topic_family" "reject" "interest" "engd" "ignrd" "deflc" "status" "cooldown_until"
            printf "%-20s  %8s  %8s  %6s  %6s  %6s  %-10s  %s\n" \
                "------------" "------" "--------" "----" "-----" "-----" "------" "--------------"
            while IFS='|' read -r family reject interest engaged ignored deflected cooldown undertaker updated; do
                [[ -z "${family}" ]] && continue
                local status_label=""
                if [[ "$undertaker" == "1" ]]; then
                    status_label="UNDERTAKER"
                elif [[ -n "$cooldown" ]]; then
                    status_label="cooldown"
                else
                    status_label="-"
                fi
                printf "%-20s  %8.2f  %8.2f  %6d  %6d  %6d  %-10s  %s\n" \
                    "$family" "$reject" "$interest" "$engaged" "$ignored" "$deflected" "$status_label" "$cooldown"
            done <<< "$rows"
            ;;

        undertaker-clear)
            [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]] && { echo "Usage: joi-admin wind undertaker-clear <conversation_id> <family>"; exit 0; }
            local conversation="${1:-}"
            local family="${2:-}"
            [[ -z "$conversation" ]] && error "undertaker-clear requires a conversation_id"
            [[ -z "$family" ]] && error "undertaker-clear requires a topic_family"

            local conversation_escaped family_escaped
            conversation_escaped=$(sql_escape_literal "$conversation")
            family_escaped=$(sql_escape_literal "$family")

            db_exec "UPDATE topic_feedback SET undertaker = 0, cooldown_until = NULL, updated_at = datetime('now') WHERE conversation_id = '$conversation_escaped' AND topic_family = '$family_escaped';"
            echo "Cleared undertaker flag for family '$family' in conversation '$conversation'."
            ;;

        undertaker-list)
            [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]] && { echo "Usage: joi-admin wind undertaker-list <conversation_id>"; exit 0; }
            local conversation="${1:-}"
            [[ -z "$conversation" ]] && error "undertaker-list requires a conversation_id"
            local conversation_escaped
            conversation_escaped=$(sql_escape_literal "$conversation")
            local rows
            rows=$(db_exec "SELECT topic_family, rejection_weight, deflection_count, updated_at FROM topic_feedback WHERE conversation_id = '$conversation_escaped' AND undertaker = 1 ORDER BY topic_family;")
            if [[ -z "${rows//[$'\t\r\n ']/}" ]]; then
                echo "No undertaker families for '$conversation'."
                exit 0
            fi
            echo "Undertaker families for: $conversation"
            echo ""
            printf "%-24s  %8s  %6s  %s\n" "topic_family" "reject" "deflct" "blocked_since"
            printf "%-24s  %8s  %6s  %s\n" "------------" "------" "------" "-------------"
            while IFS='|' read -r family reject deflected updated; do
                [[ -z "$family" ]] && continue
                printf "%-24s  %8.2f  %6d  %s\n" "$family" "$reject" "$deflected" "$updated"
            done <<< "$rows"
            ;;

        undertaker-poke)
            [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]] && { echo "Usage: joi-admin wind undertaker-poke <conversation_id> [family]"; exit 0; }
            local conversation="${1:-}"
            local family="${2:-}"
            [[ -z "$conversation" ]] && error "undertaker-poke requires a conversation_id"

            local conversation_escaped
            conversation_escaped=$(sql_escape_literal "$conversation")

            # If no family given, pick a random one from undertaker
            if [[ -z "$family" ]]; then
                family=$(db_scalar "SELECT topic_family FROM topic_feedback WHERE conversation_id = '$conversation_escaped' AND undertaker = 1 ORDER BY RANDOM() LIMIT 1;")
                [[ -z "$family" ]] && { echo "No undertaker families found for '$conversation'."; exit 0; }
            fi

            local family_escaped
            family_escaped=$(sql_escape_literal "$family")

            # Check it is actually in undertaker
            local in_undertaker
            in_undertaker=$(db_scalar "SELECT undertaker FROM topic_feedback WHERE conversation_id = '$conversation_escaped' AND topic_family = '$family_escaped';")
            [[ "$in_undertaker" != "1" ]] && error "Family '$family' is not in undertaker for '$conversation'"

            local novelty_key="poke_manual_$(date +%Y-%m-%d_%H%M%S)"
            local title="Undertaker challenge: $family"
            local content="The user has strongly rejected '$family' topics in the past and you've stopped bringing them up. Now playfully challenge that. Invent your own opener — something joyful, curious, or lightly sarcastic that reflects your personality. You might express genuine enthusiasm, feign disbelief at their taste, or frame it as a personal affront. Keep it short, fun, and not pushy. If they engage, great. If not, drop it."
            local now
            now=$(date -u +"%Y-%m-%dT%H:%M:%S")

            local title_escaped content_escaped
            title_escaped=$(sql_escape_literal "$title")
            content_escaped=$(sql_escape_literal "$content")

            db_exec "INSERT OR IGNORE INTO pending_topics (conversation_id, topic_type, title, content, priority, status, novelty_key, created_at) VALUES ('$conversation_escaped', 'poke', '$title_escaped', '$content_escaped', 60, 'pending', '$novelty_key', '$now');"
            echo "Queued undertaker poke for family '$family' in conversation '$conversation'."
            ;;

        clear-cooldowns)
            [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]] && { echo "Usage: joi-admin wind clear-cooldowns <conversation_id>"; exit 0; }
            local conversation="${1:-}"
            [[ -z "$conversation" ]] && error "clear-cooldowns requires a conversation_id"

            local conversation_escaped
            conversation_escaped=$(sql_escape_literal "$conversation")

            local count
            count=$(db_scalar "SELECT COUNT(*) FROM topic_feedback WHERE conversation_id = '$conversation_escaped' AND cooldown_until IS NOT NULL AND cooldown_until > datetime('now');")

            if [[ "${count:-0}" == "0" ]]; then
                echo "No active cooldowns found for conversation '$conversation'."
                exit 0
            fi

            echo ""
            echo "=== CLEAR COOLDOWNS ==="
            echo "  Conversation: $conversation"
            echo "  Active cooldowns: $count"
            echo ""

            read -p "Clear all cooldowns? [y/N] " -n 1 -r
            echo
            if [[ ! $REPLY =~ ^[Yy]$ ]]; then
                echo "Aborted."
                exit 1
            fi

            local now
            now=$(date -Iseconds)
            db_exec "UPDATE topic_feedback SET cooldown_until = NULL, updated_at = '$now' WHERE conversation_id = '$conversation_escaped';"

            info "Cleared $count cooldowns for '$conversation'"
            ;;

        reset-engagement)
            [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]] && { echo "Usage: joi-admin wind reset-engagement [conversation_id]"; exit 0; }
            local conversation="${1:-}"

            local now
            now=$(date -Iseconds)

            if [[ -n "$conversation" ]]; then
                local conversation_escaped
                conversation_escaped=$(sql_escape_literal "$conversation")
                local count
                count=$(db_scalar "SELECT COUNT(*) FROM wind_state WHERE conversation_id = '$conversation_escaped';")
                [[ "$count" -eq 0 ]] && error "No wind state found for '$conversation'"
                db_exec "UPDATE wind_state SET engagement_score = 0.5, total_engaged = 0, total_ignored = 0, total_deflected = 0, last_engaged_at = NULL, last_deflected_at = NULL, updated_at = '$now' WHERE conversation_id = '$conversation_escaped';"
                info "Reset engagement for '$conversation' (score → 0.5, counters → 0)"
            else
                local count
                count=$(db_scalar "SELECT COUNT(*) FROM wind_state;")
                [[ "$count" -eq 0 ]] && error "No wind state found"
                db_exec "UPDATE wind_state SET engagement_score = 0.5, total_engaged = 0, total_ignored = 0, total_deflected = 0, last_engaged_at = NULL, last_deflected_at = NULL, updated_at = '$now';"
                info "Reset engagement for all conversations (score → 0.5, counters → 0)"
            fi
            ;;

        snooze)
            [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]] && { echo "Usage: joi-admin wind snooze <conversation_id> <duration>  (e.g. 2h, 30m, 1d)"; exit 0; }
            local conversation="${1:-}"
            local duration="${2:-}"
            [[ -z "$conversation" ]] && error "snooze requires a conversation_id and duration (e.g. joi-admin wind snooze +1234567890 2h)"
            [[ -z "$duration" ]] && error "snooze requires a duration (e.g. 2h, 30m, 1d)"

            local conversation_escaped
            conversation_escaped=$(sql_escape_literal "$conversation")

            # Parse duration: accept Nh (hours), Nm (minutes), Nd (days)
            local seconds=0
            if [[ "$duration" =~ ^([0-9]+)h$ ]]; then
                seconds=$(( ${BASH_REMATCH[1]} * 3600 ))
            elif [[ "$duration" =~ ^([0-9]+)m$ ]]; then
                seconds=$(( ${BASH_REMATCH[1]} * 60 ))
            elif [[ "$duration" =~ ^([0-9]+)d$ ]]; then
                seconds=$(( ${BASH_REMATCH[1]} * 86400 ))
            else
                error "Invalid duration '$duration'. Use format: 2h, 30m, 1d"
            fi

            db_exec "INSERT INTO wind_state (conversation_id, wind_snooze_until, updated_at)
                     VALUES ('$conversation_escaped', datetime('now', 'localtime', '+${seconds} seconds'), datetime('now', 'localtime'))
                     ON CONFLICT(conversation_id) DO UPDATE SET
                         wind_snooze_until = datetime('now', 'localtime', '+${seconds} seconds'),
                         updated_at = datetime('now', 'localtime');"

            local until_time
            until_time=$(db_scalar "SELECT wind_snooze_until FROM wind_state WHERE conversation_id = '$conversation_escaped';")
            info "Wind snoozed for '$conversation' until $until_time (${duration})"
            ;;

        snooze-clear)
            [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]] && { echo "Usage: joi-admin wind snooze-clear <conversation_id>"; exit 0; }
            local conversation="${1:-}"
            [[ -z "$conversation" ]] && error "snooze-clear requires a conversation_id"

            local conversation_escaped
            conversation_escaped=$(sql_escape_literal "$conversation")

            db_exec "UPDATE wind_state SET wind_snooze_until = NULL, updated_at = datetime('now') WHERE conversation_id = '$conversation_escaped';"
            info "Wind snooze cleared for '$conversation'"
            ;;

        revive-topic)
            [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]] && { echo "Usage: joi-admin wind revive-topic <id>"; exit 0; }
            local topic_id="${1:-}"
            [[ -z "$topic_id" ]] && error "revive-topic requires a topic id (e.g. joi-admin wind revive-topic 7)"
            [[ ! "$topic_id" =~ ^[0-9]+$ ]] && error "Topic id must be a number"

            local row
            row=$(db_scalar "SELECT id || '|' || status || '|' || COALESCE(title,'') FROM pending_topics WHERE id = $topic_id;")
            [[ -z "$row" ]] && error "No topic found with id $topic_id"

            local cur_status title
            cur_status=$(echo "$row" | cut -d'|' -f2)
            title=$(echo "$row" | cut -d'|' -f3)

            echo ""
            echo "=== REVIVE TOPIC ==="
            printf "  ID:     %s\n" "$topic_id"
            printf "  Title:  %s\n" "$title"
            printf "  Status: %s → pending\n" "$cur_status"
            echo ""

            read -p "Revive this topic? [y/N] " -n 1 -r
            echo
            if [[ ! $REPLY =~ ^[Yy]$ ]]; then
                echo "Aborted."
                exit 1
            fi

            db_exec "UPDATE pending_topics SET status = 'pending', outcome = NULL, outcome_at = NULL, mentioned_at = NULL, retry_count = 0, expires_at = NULL WHERE id = $topic_id;"
            info "Topic #$topic_id revived to pending"
            ;;

        topic-list)
            local conversation="" status_filter="" type_filter="" limit="20"
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --conversation)
                        [[ -z "${2:-}" ]] && error "--conversation requires a value"
                        conversation="$2"; shift 2 ;;
                    --status)
                        [[ -z "${2:-}" ]] && error "--status requires a value"
                        status_filter="$2"; shift 2 ;;
                    --type)
                        [[ -z "${2:-}" ]] && error "--type requires a value"
                        type_filter="$2"; shift 2 ;;
                    --limit)
                        [[ -z "${2:-}" ]] && error "--limit requires a number"
                        [[ ! "$2" =~ ^[0-9]+$ ]] && error "--limit must be a positive integer"
                        limit="$2"; shift 2 ;;
                    --help|-h)
                        echo "Usage: joi-admin wind topic-list [--conversation ID] [--status STATUS] [--type TYPE] [--limit N]"
                        echo ""
                        echo "List pending topics with optional filters."
                        echo ""
                        echo "Options:"
                        echo "  --conversation ID   Filter by conversation id"
                        echo "  --status STATUS     Filter by status (pending|mentioned|dismissed|awaiting_response)"
                        echo "  --type TYPE         Filter by topic type (discovery|reminder|ghost|...)"
                        echo "  --limit N           Max rows to return (default: 20)"
                        exit 0 ;;
                    *) error "Unknown option for 'wind topic-list': $1" ;;
                esac
            done

            local where_parts=()
            if [[ -n "$conversation" ]]; then
                local conversation_escaped
                conversation_escaped=$(sql_escape_literal "$conversation")
                where_parts+=("conversation_id = '$conversation_escaped'")
            fi
            if [[ -n "$status_filter" ]]; then
                local status_escaped
                status_escaped=$(sql_escape_literal "$status_filter")
                where_parts+=("status = '$status_escaped'")
            fi
            if [[ -n "$type_filter" ]]; then
                local type_escaped
                type_escaped=$(sql_escape_literal "$type_filter")
                where_parts+=("topic_type = '$type_escaped'")
            fi

            local where_clause=""
            if [[ ${#where_parts[@]} -gt 0 ]]; then
                where_clause="WHERE $(IFS=' AND '; echo "${where_parts[*]}")"
            fi

            local rows
            rows=$(db_exec "$(cat <<SQL
SELECT
    id,
    topic_type,
    substr(title, 1, 32),
    status,
    COALESCE(outcome, '-'),
    COALESCE(retry_count, 0),
    COALESCE(created_at, ''),
    COALESCE(mentioned_at, '-')
FROM pending_topics
$where_clause
ORDER BY created_at DESC
LIMIT $limit;
SQL
)" | awk 'NF && $0 != "ok"')

            if [[ -z "${rows//[$'\t\r\n ']/}" ]]; then
                echo "No topics found."
                exit 0
            fi

            printf "%6s  %-12s  %-32s  %-18s  %-10s  %5s  %s\n" \
                "id" "type" "title" "status" "outcome" "retry" "mentioned_at"
            printf "%6s  %-12s  %-32s  %-18s  %-10s  %5s  %s\n" \
                "--" "----" "-----" "------" "-------" "-----" "------------"
            while IFS='|' read -r tid ttype title status outcome retry created mentioned; do
                [[ -z "${tid}" ]] && continue
                printf "%6d  %-12s  %-32s  %-18s  %-10s  %5d  %s\n" \
                    "$tid" "$ttype" "$title" "$status" "$outcome" "$retry" "$mentioned"
            done <<< "$rows"
            ;;

        topic-show)
            local topic_id="${1:-}"
            if [[ -z "$topic_id" || "$topic_id" == "--help" || "$topic_id" == "-h" ]]; then
                echo "Usage: joi-admin wind topic-show <id>"
                echo ""
                echo "Show all fields for a single topic."
                exit 0
            fi
            [[ ! "$topic_id" =~ ^[0-9]+$ ]] && error "Topic id must be a number"

            local exists
            exists=$(db_scalar "SELECT COUNT(*) FROM pending_topics WHERE id = $topic_id;")
            [[ "${exists:-0}" == "0" ]] && error "No topic found with id $topic_id"

            echo ""
            echo "=== TOPIC #$topic_id ==="
            printf "  %-18s %s\n" "id:" "$(db_scalar "SELECT id FROM pending_topics WHERE id = $topic_id;")"
            printf "  %-18s %s\n" "conversation_id:" "$(db_scalar "SELECT COALESCE(conversation_id,'') FROM pending_topics WHERE id = $topic_id;")"
            printf "  %-18s %s\n" "type:" "$(db_scalar "SELECT COALESCE(topic_type,'') FROM pending_topics WHERE id = $topic_id;")"
            printf "  %-18s %s\n" "title:" "$(db_scalar "SELECT COALESCE(title,'') FROM pending_topics WHERE id = $topic_id;")"
            printf "  %-18s %s\n" "status:" "$(db_scalar "SELECT COALESCE(status,'') FROM pending_topics WHERE id = $topic_id;")"
            printf "  %-18s %s\n" "outcome:" "$(db_scalar "SELECT COALESCE(outcome,'-') FROM pending_topics WHERE id = $topic_id;")"
            printf "  %-18s %s\n" "priority:" "$(db_scalar "SELECT COALESCE(priority,0) FROM pending_topics WHERE id = $topic_id;")"
            printf "  %-18s %s\n" "retry_count:" "$(db_scalar "SELECT COALESCE(retry_count,0) FROM pending_topics WHERE id = $topic_id;")"
            printf "  %-18s %s\n" "created_at:" "$(db_scalar "SELECT COALESCE(created_at,'-') FROM pending_topics WHERE id = $topic_id;")"
            printf "  %-18s %s\n" "expires_at:" "$(db_scalar "SELECT COALESCE(expires_at,'-') FROM pending_topics WHERE id = $topic_id;")"
            printf "  %-18s %s\n" "due_at:" "$(db_scalar "SELECT COALESCE(due_at,'-') FROM pending_topics WHERE id = $topic_id;")"
            printf "  %-18s %s\n" "mentioned_at:" "$(db_scalar "SELECT COALESCE(mentioned_at,'-') FROM pending_topics WHERE id = $topic_id;")"
            printf "  %-18s %s\n" "outcome_at:" "$(db_scalar "SELECT COALESCE(outcome_at,'-') FROM pending_topics WHERE id = $topic_id;")"
            printf "  %-18s %s\n" "novelty_key:" "$(db_scalar "SELECT COALESCE(novelty_key,'-') FROM pending_topics WHERE id = $topic_id;")"
            printf "  %-18s %s\n" "source_event_id:" "$(db_scalar "SELECT COALESCE(source_event_id,'-') FROM pending_topics WHERE id = $topic_id;")"
            printf "  %-18s %s\n" "sent_message_id:" "$(db_scalar "SELECT COALESCE(sent_message_id,'-') FROM pending_topics WHERE id = $topic_id;")"
            local content
            content=$(db_scalar "SELECT COALESCE(content,'') FROM pending_topics WHERE id = $topic_id;")
            if [[ -n "$content" ]]; then
                echo ""
                echo "  --- content ---"
                echo "$content" | fold -s -w 72 | sed 's/^/  /'
            fi
            echo ""
            ;;

        topic-delete)
            local topic_id="${1:-}"
            if [[ -z "$topic_id" || "$topic_id" == "--help" || "$topic_id" == "-h" ]]; then
                echo "Usage: joi-admin wind topic-delete <id>"
                echo ""
                echo "Delete a single topic by ID (with confirmation)."
                exit 0
            fi
            [[ ! "$topic_id" =~ ^[0-9]+$ ]] && error "Topic id must be a number"

            local row
            row=$(db_scalar "SELECT id || '|' || topic_type || '|' || status || '|' || COALESCE(title,'') FROM pending_topics WHERE id = $topic_id;")
            [[ -z "$row" ]] && error "No topic found with id $topic_id"

            local ttype cur_status title
            ttype=$(echo "$row" | cut -d'|' -f2)
            cur_status=$(echo "$row" | cut -d'|' -f3)
            title=$(echo "$row" | cut -d'|' -f4)

            echo ""
            echo "=== DELETE TOPIC ==="
            printf "  ID:     %s\n" "$topic_id"
            printf "  Type:   %s\n" "$ttype"
            printf "  Status: %s\n" "$cur_status"
            printf "  Title:  %s\n" "$title"
            echo ""

            read -p "Delete this topic? [y/N] " -n 1 -r
            echo
            if [[ ! $REPLY =~ ^[Yy]$ ]]; then
                echo "Aborted."
                exit 1
            fi

            db_exec "DELETE FROM pending_topics WHERE id = $topic_id;"
            info "  Deleted topic #$topic_id"
            ;;

        topic-purge)
            local conversation=""
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --conversation)
                        [[ -z "${2:-}" ]] && error "--conversation requires a value"
                        conversation="$2"; shift 2 ;;
                    --help|-h)
                        echo "Usage: joi-admin wind topic-purge --conversation ID"
                        echo ""
                        echo "Delete all topics for a conversation (with confirmation)."
                        echo ""
                        echo "Options:"
                        echo "  --conversation ID   Conversation id to purge topics for (required)"
                        exit 0 ;;
                    *) error "Unknown option for 'wind topic-purge': $1" ;;
                esac
            done
            [[ -z "$conversation" ]] && error "topic-purge requires --conversation ID"

            local conversation_escaped
            conversation_escaped=$(sql_escape_literal "$conversation")

            local count
            count=$(db_scalar "SELECT COUNT(*) FROM pending_topics WHERE conversation_id = '$conversation_escaped';")

            if [[ "${count:-0}" == "0" ]]; then
                echo "No topics found for conversation '$conversation'."
                exit 0
            fi

            echo ""
            echo "=== PURGE TOPICS ==="
            printf "  Conversation: %s\n" "$conversation"
            printf "  Topics:       %s\n" "$count"
            echo ""

            read -p "Delete all $count topics for this conversation? [y/N] " -n 1 -r
            echo
            if [[ ! $REPLY =~ ^[Yy]$ ]]; then
                echo "Aborted."
                exit 1
            fi

            db_exec "DELETE FROM pending_topics WHERE conversation_id = '$conversation_escaped';"
            info "  Deleted $count topics for '$conversation'"
            ;;

        decision-log)
            local conversation="" decision_filter="" limit="50"
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --conversation)
                        [[ -z "${2:-}" ]] && error "--conversation requires a value"
                        conversation="$2"; shift 2 ;;
                    --decision)
                        [[ -z "${2:-}" ]] && error "--decision requires a value"
                        case "$2" in
                            send|skip|shadow_logged) ;;
                            *) error "--decision must be one of: send, skip, shadow_logged" ;;
                        esac
                        decision_filter="$2"; shift 2 ;;
                    --limit)
                        [[ -z "${2:-}" ]] && error "--limit requires a number"
                        # Regex is the security gate for $limit interpolation into SQL
                        [[ ! "$2" =~ ^[0-9]+$ ]] && error "--limit must be a positive integer"
                        [[ "$2" -lt 1 || "$2" -gt 10000 ]] && error "--limit must be between 1 and 10000"
                        limit="$2"; shift 2 ;;
                    --help|-h)
                        cat <<'HELP'
Usage: joi-admin wind decision-log [--conversation ID] [--decision DECISION] [--limit N]
Show recent Wind tick decisions.
  --conversation ID   Filter by conversation
  --decision VALUE    Filter by decision (send|skip|shadow_logged)
  --limit N           Max rows (default: 50)
HELP
                        exit 0 ;;
                    *) error "Unknown option for 'wind decision-log': $1" ;;
                esac
            done

            local where_parts=()
            if [[ -n "$conversation" ]]; then
                local conversation_escaped
                conversation_escaped=$(sql_escape_literal "$conversation")
                where_parts+=("conversation_id = '$conversation_escaped'")
            fi
            if [[ -n "$decision_filter" ]]; then
                local decision_escaped
                decision_escaped=$(sql_escape_literal "$decision_filter")
                where_parts+=("decision = '$decision_escaped'")
            fi

            local where_clause=""
            if [[ ${#where_parts[@]} -gt 0 ]]; then
                where_clause="WHERE $(IFS=' AND '; echo "${where_parts[*]}")"
            fi

            local rows
            rows=$(db_exec "$(cat <<SQL
SELECT
    timestamp,
    conversation_id,
    decision,
    COALESCE(impulse_score, 0.0),
    COALESCE(threshold, 0.0),
    COALESCE(skip_reason, '-'),
    COALESCE(selected_topic_id, '-')
FROM wind_decision_log
$where_clause
ORDER BY timestamp DESC
LIMIT $limit;
SQL
)" | awk 'NF && $0 != "ok"')

            if [[ -z "${rows//[$'\t\r\n ']/}" ]]; then
                echo "No decision log entries found."
                exit 0
            fi

            printf "%-19s  %-28s  %-12s  %7s  %9s  %-22s  %s\n" \
                "timestamp" "conversation_id" "decision" "score" "threshold" "skip_reason" "topic_id"
            printf "%-19s  %-28s  %-12s  %7s  %9s  %-22s  %s\n" \
                "---------" "---------------" "--------" "-----" "---------" "-----------" "--------"
            while IFS='|' read -r ts conv_id decision score threshold skip_reason topic_id; do
                [[ -z "${ts}" ]] && continue
                printf "%-19s  %-28s  %-12s  %7.3f  %9.3f  %-22s  %s\n" \
                    "$ts" "$conv_id" "$decision" "$score" "$threshold" "$skip_reason" "$topic_id"
            done <<< "$rows"
            ;;

        --help|-h)
            cat <<'HELP'
Usage: joi-admin wind <subcommand> [OPTIONS]

Wind state subcommands:
  show-windmood     [conversation_id]                Show WindMood state
  reset-windmood    <conversation_id>                Reset WindMood to defaults
  set-windmood      <conversation_id> [--offset N] [--impulse N]  Set WindMood values
  show-engagement   [conversation_id]                Show engagement metrics
  reset-engagement  [conversation_id]                Reset engagement counters
  show-feedback     <conversation_id>                Show topic family feedback
  undertaker-clear  <conversation_id> <family>       Remove undertaker flag
  undertaker-list   <conversation_id>                List all undertaker-blocked families
  undertaker-poke   <conversation_id> [family]       Queue a playful poke for an undertaker family
  clear-cooldowns   <conversation_id>                Clear all cooldown timers
  snooze            <conversation_id> <duration>     Pause Wind (e.g. 2h, 30m, 1d)
  snooze-clear      <conversation_id>                Clear Wind snooze

Decision log:
  decision-log  [--conversation ID] [--decision D] [--limit N]  Show recent tick decisions

Topic subcommands:
  topic-list    [--conversation ID] [--status S] [--type T] [--limit N]
  topic-show    <id>
  topic-delete  <id>
  topic-purge   --conversation ID
  revive-topic  <id>                                 Reset topic back to pending

Examples:
  joi-admin wind decision-log
  joi-admin wind decision-log --conversation +1234567890
  joi-admin wind decision-log --decision skip --limit 20
  joi-admin wind topic-list --conversation +1234567890
  joi-admin wind topic-list --status pending --type discovery
  joi-admin wind topic-show 8
  joi-admin wind topic-delete 9
  joi-admin wind topic-purge --conversation +1234567890
HELP
            exit 0
            ;;

        *)
            error "Unknown wind subcommand: $subcommand"
            ;;
    esac
}

# Main purge command
cmd_purge() {
    local do_contexts=false
    local do_facts=false
    local do_knowledge=false
    local do_reset_counters=false
    local do_vacuum=false
    local do_hmac=false
    local do_nebula_keys=false
    local do_nebula_ca=false
    local conversation=""

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --contexts)
                do_contexts=true
                shift
                ;;
            --facts)
                do_facts=true
                shift
                ;;
            --knowledge)
                do_knowledge=true
                shift
                ;;
            --all-data)
                do_contexts=true
                do_facts=true
                do_knowledge=true
                shift
                ;;
            --reset-counters)
                do_reset_counters=true
                shift
                ;;
            --vacuum)
                do_vacuum=true
                shift
                ;;
            --conversation)
                [[ -z "${2:-}" ]] && error "--conversation requires an ID"
                conversation="$2"
                shift 2
                ;;
            --hmac-key)
                do_hmac=true
                shift
                ;;
            --nebula-keys)
                do_nebula_keys=true
                shift
                ;;
            --all-keys)
                do_hmac=true
                do_nebula_keys=true
                shift
                ;;
            --everything)
                do_contexts=true
                do_facts=true
                do_knowledge=true
                do_hmac=true
                do_nebula_keys=true
                shift
                ;;
            --nebula-ca)
                do_nebula_ca=true
                shift
                ;;
            --help|-h)
                usage
                ;;
            *)
                error "Unknown option: $1"
                ;;
        esac
    done

    # Check if anything to do
    if ! $do_contexts && ! $do_facts && ! $do_knowledge && ! $do_hmac && ! $do_nebula_keys && ! $do_nebula_ca && ! $do_reset_counters && ! $do_vacuum; then
        echo "No purge flags specified. Nothing to do."
        echo ""
        echo "Run 'joi-admin purge --help' for usage."
        exit 0
    fi

    # Safety check for nuclear options
    if $do_nebula_ca && ! $do_nebula_keys; then
        error "--nebula-ca requires --nebula-keys or --everything"
    fi

    # Counter reset safety checks
    if $do_reset_counters; then
        if [[ -n "$conversation" ]]; then
            error "--reset-counters cannot be used with --conversation"
        fi
        if ! $do_contexts || ! $do_facts || ! $do_knowledge; then
            error "--reset-counters requires full memory purge: --all-data (or --contexts --facts --knowledge)"
        fi
    fi

    # Vacuum safety checks
    if $do_vacuum; then
        if [[ -n "$conversation" ]]; then
            error "--vacuum cannot be used with --conversation"
        fi
        if ! $do_contexts || ! $do_facts || ! $do_knowledge; then
            error "--vacuum requires full memory purge: --all-data (or --contexts --facts --knowledge)"
        fi
    fi

    # Confirm destructive action
    echo ""
    echo "=== PURGE SUMMARY ==="
    $do_contexts && echo "  - Contexts (messages, summaries)"
    $do_facts && echo "  - User facts"
    $do_knowledge && echo "  - Knowledge chunks"
    $do_reset_counters && echo "  - Reset AUTOINCREMENT counters"
    $do_vacuum && echo "  - VACUUM memory database"
    $do_hmac && echo "  - HMAC key (regenerate)"
    $do_nebula_keys && echo "  - Nebula host keys"
    $do_nebula_ca && echo "  - Nebula CA certificate"
    [[ -n "$conversation" ]] && echo "  Scope: conversation $conversation" || echo "  Scope: ALL"
    echo ""

    read -p "Are you sure? This cannot be undone. [y/N] " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        echo "Aborted."
        exit 1
    fi

    if $do_vacuum; then
        echo ""
        warn "VACUUM rewrites the entire database file."
        warn "Ensure sufficient free disk space (roughly at least DB size)."
        warn "If joi-api is running and writing to DB, VACUUM can fail (database locked)."
        warn "Recommended: stop joi-api before running purge with --vacuum."

        read -p "Proceed with VACUUM after purge? [y/N] " -n 1 -r
        echo
        if [[ ! $REPLY =~ ^[Yy]$ ]]; then
            echo "Aborted."
            exit 1
        fi

        read -p "Confirm VACUUM again (second confirmation) [y/N] " -n 1 -r
        echo
        if [[ ! $REPLY =~ ^[Yy]$ ]]; then
            echo "Aborted."
            exit 1
        fi
    fi

    echo ""
    echo "=== PURGING ==="

    # Execute purges
    $do_contexts && purge_contexts "$conversation"
    $do_facts && purge_facts "$conversation"
    $do_knowledge && purge_knowledge
    $do_reset_counters && reset_autoincrement_counters
    $do_vacuum && vacuum_memory_db

    # Reset system state if purging all data
    if $do_contexts && $do_facts && [[ -z "$conversation" ]]; then
        reset_system_state
    fi

    $do_hmac && regenerate_hmac
    $do_nebula_keys && purge_nebula_keys
    $do_nebula_ca && purge_nebula_ca

    echo ""
    info "=== PURGE COMPLETE ==="

    # Reminders
    if $do_hmac; then
        echo ""
        warn "REMINDER: Update HMAC key on Mesh VM to match!"
    fi

    if $do_nebula_keys || $do_nebula_ca; then
        echo ""
        warn "REMINDER: Nebula re-enrollment required before network connectivity!"
    fi
}

cmd_facts() {
    if [[ ! -f "$MEMORY_DB" ]]; then
        error "Memory database not found: $MEMORY_DB"
    fi

    local subcommand="${1:-}"
    [[ -z "$subcommand" ]] && error "Usage: joi-admin facts <list|show|add|reschedule|delete|delete-all> [OPTIONS]"
    shift || true

    case "$subcommand" in
        show)
            local fact_id="${1:-}"
            [[ -z "$fact_id" ]] && error "show requires a fact ID"
            [[ ! "$fact_id" =~ ^[0-9]+$ ]] && error "Fact ID must be a number"

            local exists
            exists=$(db_scalar "SELECT COUNT(*) FROM user_facts WHERE id = $fact_id;")
            if [[ "${exists:-0}" == "0" ]]; then
                echo "Fact #$fact_id not found."
                exit 1
            fi

            # Query each field separately to avoid pipe-in-value splitting issues
            local f_conv f_cat f_key f_val f_conf f_src f_act f_imp f_learned f_updated f_expires f_detected
            f_conv=$(db_scalar     "SELECT conversation_id FROM user_facts WHERE id = $fact_id;")
            f_cat=$(db_scalar      "SELECT category        FROM user_facts WHERE id = $fact_id;")
            f_key=$(db_scalar      "SELECT key             FROM user_facts WHERE id = $fact_id;")
            f_val=$(db_scalar      "SELECT value           FROM user_facts WHERE id = $fact_id;")
            f_conf=$(db_scalar     "SELECT confidence      FROM user_facts WHERE id = $fact_id;")
            f_src=$(db_scalar      "SELECT source          FROM user_facts WHERE id = $fact_id;")
            f_act=$(db_scalar      "SELECT active          FROM user_facts WHERE id = $fact_id;")
            f_imp=$(db_scalar      "SELECT important       FROM user_facts WHERE id = $fact_id;")
            f_learned=$(db_scalar  "SELECT datetime(learned_at/1000,'unixepoch') FROM user_facts WHERE id = $fact_id;")
            f_updated=$(db_scalar  "SELECT datetime(updated_at/1000,'unixepoch') FROM user_facts WHERE id = $fact_id;")
            f_expires_raw=$(db_scalar "SELECT expires_at FROM user_facts WHERE id = $fact_id;")
            f_detected_raw=$(db_scalar "SELECT detected_at FROM user_facts WHERE id = $fact_id;")

            if [[ -z "$f_expires_raw" ]]; then
                f_expires="-"
            else
                local exp_dt exp_now_sec exp_fact_sec
                exp_dt=$(db_scalar "SELECT datetime($f_expires_raw/1000,'unixepoch');")
                exp_now_sec=$(date +%s)
                exp_fact_sec=$(( f_expires_raw / 1000 ))
                if [[ $exp_fact_sec -lt $exp_now_sec ]]; then
                    f_expires="$exp_dt [expired]"
                else
                    f_expires="$exp_dt"
                fi
            fi

            if [[ -z "$f_detected_raw" ]]; then
                f_detected="-"
            else
                f_detected=$(db_scalar "SELECT datetime($f_detected_raw/1000,'unixepoch');")
            fi

            echo "ID:              $fact_id"
            echo "conversation_id: $f_conv"
            echo "category:        $f_cat"
            echo "key:             $f_key"
            echo "value:           $f_val"
            echo "confidence:      $f_conf"
            echo "source:          $f_src"
            echo "active:          $f_act"
            echo "important:       $f_imp"
            echo "learned_at:      $f_learned"
            echo "updated_at:      $f_updated"
            echo "expires_at:      $f_expires"
            echo "detected_at:     $f_detected (first mentioned at)"
            ;;

        list)
            local conversation=""
            local category=""
            local order_by="id"
            local include_expired=0

            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --conversation)
                        [[ -z "${2:-}" ]] && error "--conversation requires a value"
                        conversation="$2"
                        shift 2
                        ;;
                    --category)
                        [[ -z "${2:-}" ]] && error "--category requires a value"
                        category="$2"
                        shift 2
                        ;;
                    --order-by)
                        [[ -z "${2:-}" ]] && error "--order-by requires a value (id|date|category|key)"
                        case "$2" in
                            id)       order_by="id" ;;
                            date)     order_by="updated_at DESC" ;;
                            category) order_by="category, key" ;;
                            key)      order_by="key" ;;
                            *)        error "--order-by must be one of: id, date, category, key" ;;
                        esac
                        shift 2
                        ;;
                    --include-expired)
                        include_expired=1
                        shift
                        ;;
                    --help|-h)
                        echo "Usage: joi-admin facts list [--conversation ID] [--category CAT] [--order-by id|date|category|key] [--include-expired]"
                        exit 0
                        ;;
                    *)
                        error "Unknown option for 'facts list': $1"
                        ;;
                esac
            done

            local where_parts=()
            if [[ -n "$conversation" ]]; then
                local conv_esc
                conv_esc=$(sql_escape_literal "$conversation")
                where_parts+=("conversation_id = '$conv_esc'")
            fi
            if [[ -n "$category" ]]; then
                local cat_esc
                cat_esc=$(sql_escape_literal "$category")
                where_parts+=("category = '$cat_esc'")
            fi
            if [[ "$include_expired" -eq 0 ]]; then
                local now_ms
                now_ms=$(date +%s%3N)
                where_parts+=("(expires_at IS NULL OR expires_at > $now_ms)")
            fi

            local where_clause=""
            if [[ ${#where_parts[@]} -gt 0 ]]; then
                where_clause="WHERE $(IFS=' AND '; echo "${where_parts[*]}")"
            fi

            # Use char(1) as column separator to avoid splitting on | in LLM-generated values.
            # replace(value, char(10), ' ') collapses newlines so multi-line values stay on one row.
            local rows
            rows=$(db_exec "$(cat <<SQL
SELECT
    id || char(1) ||
    conversation_id || char(1) ||
    category || char(1) ||
    key || char(1) ||
    trim(replace(replace(value, char(10), ' '), char(13), '')) || char(1) ||
    COALESCE(source, '') || char(1) ||
    active || char(1) ||
    important || char(1) ||
    CASE
        WHEN expires_at IS NULL THEN '-'
        WHEN expires_at <= strftime('%s','now')*1000 THEN datetime(expires_at/1000,'unixepoch') || ' [expired]'
        ELSE datetime(expires_at/1000,'unixepoch')
    END || char(1) ||
    CASE
        WHEN detected_at IS NULL THEN '-'
        ELSE datetime(detected_at/1000,'unixepoch')
    END
FROM user_facts
$where_clause
ORDER BY $order_by;
SQL
)" | awk 'NF && $0 != "ok"')

            if [[ -z "${rows//[$'\t\r\n ']/}" ]]; then
                echo "No facts found."
                exit 0
            fi

            printf "%-4s  %-20s  %-12s  %-20s  %-28s  %-8s  %s  %s  %-19s  %s\n" \
                "ID" "conversation_id" "category" "key" "value" "source" "act" "imp" "expires_at" "detected_at"
            printf "%-4s  %-20s  %-12s  %-20s  %-28s  %-8s  %s  %s  %-19s  %s\n" \
                "----" "--------------------" "------------" "--------------------" \
                "----------------------------" "--------" "---" "---" "-------------------" "-------------------"
            while IFS=$'\x01' read -r id conv cat key val src act imp exp det; do
                [[ -z "$id" ]] && continue
                # If value looks like JSON, extract the first string field value
                if [[ "$val" == "{"* ]]; then
                    val=$(printf '%s' "$val" | sed 's/.*":\s*"\([^"]*\)".*/\1/')
                fi
                printf "%-4s  %-20s  %-12s  %-20s  %-28s  %-8s  %s  %s  %-19s  %s\n" \
                    "$id" "${conv:0:20}" "${cat:0:12}" "${key:0:20}" "${val:0:28}" \
                    "${src:0:8}" "$act" "$imp" "${exp:0:19}" "${det:0:19}"
            done <<< "$rows"
            ;;

        reschedule)
            local fact_id="${1:-}"
            [[ -z "$fact_id" ]] && error "reschedule requires a fact ID"
            [[ ! "$fact_id" =~ ^[0-9]+$ ]] && error "Fact ID must be a number"
            shift || true

            local expires_in=""
            local new_value=""
            local conversation_id=""

            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --expires-in)
                        [[ -z "${2:-}" ]] && error "--expires-in requires a value (hours)"
                        expires_in="$2"
                        shift 2
                        ;;
                    --value)
                        [[ -z "${2:-}" ]] && error "--value requires a value"
                        new_value="$2"
                        shift 2
                        ;;
                    --conversation)
                        [[ -z "${2:-}" ]] && error "--conversation requires a value"
                        conversation_id="$2"
                        shift 2
                        ;;
                    --help|-h)
                        echo "Usage: joi-admin facts reschedule <id> --expires-in HOURS [--value \"new text\"] [--conversation ID]"
                        exit 0
                        ;;
                    *)
                        error "Unknown option for 'facts reschedule': $1"
                        ;;
                esac
            done

            [[ -z "$expires_in" ]] && error "reschedule requires --expires-in HOURS"

            # Validate expires_in is a positive number
            if ! echo "$expires_in" | grep -qE '^[0-9]+(\.[0-9]+)?$'; then
                error "--expires-in must be a positive number (hours)"
            fi

            local conv_where=""
            if [[ -n "$conversation_id" ]]; then
                local conv_esc
                conv_esc=$(sql_escape_literal "$conversation_id")
                conv_where=" AND conversation_id = '$conv_esc'"
            fi

            local exists
            exists=$(db_scalar "SELECT COUNT(*) FROM user_facts WHERE id = $fact_id${conv_where};")
            if [[ "${exists:-0}" == "0" ]]; then
                echo "Fact #$fact_id not found."
                exit 1
            fi

            # Compute new expires_at in ms
            local now_ms new_expires_ms
            now_ms=$(date +%s%3N)
            # Use awk for float multiplication
            new_expires_ms=$(awk "BEGIN { printf \"%.0f\", $now_ms + $expires_in * 3600000 }")

            local old_val old_key
            old_key=$(db_scalar "SELECT key FROM user_facts WHERE id = $fact_id;")
            old_val=$(db_scalar "SELECT value FROM user_facts WHERE id = $fact_id;")

            if [[ -n "$new_value" ]]; then
                local val_esc
                val_esc=$(sql_escape_literal "$new_value")
                db_exec "UPDATE user_facts SET expires_at = $new_expires_ms, value = '$val_esc', updated_at = $now_ms WHERE id = $fact_id${conv_where};" > /dev/null
                info "Rescheduled fact #$fact_id ($old_key) — value updated, expires in ${expires_in}h"
            else
                db_exec "UPDATE user_facts SET expires_at = $new_expires_ms, updated_at = $now_ms WHERE id = $fact_id${conv_where};" > /dev/null
                info "Rescheduled fact #$fact_id ($old_key) — expires in ${expires_in}h"
            fi
            ;;

        delete)
            local fact_id="${1:-}"
            [[ -z "$fact_id" ]] && error "delete requires a fact ID"
            [[ ! "$fact_id" =~ ^[0-9]+$ ]] && error "Fact ID must be a number"

            local count
            count=$(db_scalar "SELECT COUNT(*) FROM user_facts WHERE id = $fact_id;")
            if [[ "${count:-0}" == "0" ]]; then
                echo "Fact #$fact_id not found."
                exit 1
            fi

            local row
            row=$(db_exec "SELECT category, key, value FROM user_facts WHERE id = $fact_id;" \
                | awk 'NF && $0 != "ok"' | head -1)

            echo ""
            echo "=== DELETE FACT ==="
            printf "  ID:   %s\n" "$fact_id"
            printf "  Fact: %s\n" "$row"
            echo ""

            read -p "Delete this fact? [y/N] " -n 1 -r
            echo
            if [[ ! $REPLY =~ ^[Yy]$ ]]; then
                echo "Aborted."
                exit 1
            fi

            delete_facts_with_python "id" "$fact_id"
            info "  Deleted fact #$fact_id"
            ;;

        delete-all)
            local conversation=""

            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --conversation)
                        [[ -z "${2:-}" ]] && error "--conversation requires a value"
                        conversation="$2"
                        shift 2
                        ;;
                    --help|-h)
                        echo "Usage: joi-admin facts delete-all [--conversation ID]"
                        exit 0
                        ;;
                    *)
                        error "Unknown option for 'facts delete-all': $1"
                        ;;
                esac
            done

            local count
            if [[ -n "$conversation" ]]; then
                local conv_esc
                conv_esc=$(sql_escape_literal "$conversation")
                count=$(db_scalar "SELECT COUNT(*) FROM user_facts WHERE conversation_id = '$conv_esc';")
            else
                count=$(db_scalar "SELECT COUNT(*) FROM user_facts;")
            fi

            if [[ "${count:-0}" == "0" ]]; then
                echo "No facts found${conversation:+ for conversation '$conversation'}."
                exit 0
            fi

            echo ""
            echo "=== FACTS DELETE SUMMARY ==="
            [[ -n "$conversation" ]] && echo "  Conversation: $conversation" || echo "  Scope: ALL conversations"
            echo "  Facts to delete: $count"
            echo ""

            read -p "Delete $count fact(s)? [y/N] " -n 1 -r
            echo
            if [[ ! $REPLY =~ ^[Yy]$ ]]; then
                echo "Aborted."
                exit 1
            fi

            if [[ -n "$conversation" ]]; then
                delete_facts_with_python "conversation" "$conversation"
            else
                delete_facts_with_python "all"
            fi

            info "Deleted $count fact(s)"
            ;;

        add)
            local conversation="" category="" key="" value="" confidence="0.9"
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --conversation) conversation="$2"; shift 2 ;;
                    --category)     category="$2";     shift 2 ;;
                    --key)          key="$2";           shift 2 ;;
                    --value)        value="$2";         shift 2 ;;
                    --confidence)   confidence="$2";   shift 2 ;;
                    --help|-h)
                        echo "Usage: joi-admin facts add --conversation ID --category CAT --key KEY --value VALUE [--confidence 0.9]"
                        exit 0
                        ;;
                    *) error "Unknown option for 'facts add': $1" ;;
                esac
            done

            [[ -z "$conversation" ]] && error "facts add requires --conversation"
            [[ -z "$category" ]]     && error "facts add requires --category"
            [[ -z "$key" ]]          && error "facts add requires --key"
            [[ -z "$value" ]]        && error "facts add requires --value"

            local new_id
            new_id=$(JOI_FACT_CONV="$conversation" \
                     JOI_FACT_CAT="$category" \
                     JOI_FACT_KEY="$key" \
                     JOI_FACT_VAL="$value" \
                     JOI_FACT_CONF="$confidence" \
                     add_fact_with_python)

            info "Fact stored (id=$new_id): [$category] $key = $value (confidence=$confidence)"
            ;;

        --help|-h)
            echo "Usage: joi-admin facts <list|show|add|reschedule|delete|delete-all> [OPTIONS]"
            exit 0
            ;;
        *)
            error "Unknown facts subcommand: $subcommand"
            ;;
    esac
}

cmd_reminders() {
    if [[ ! -f "$MEMORY_DB" ]]; then
        error "Memory database not found: $MEMORY_DB"
    fi

    local subcommand="${1:-}"
    [[ -z "$subcommand" ]] && error "Usage: joi-admin reminders <list|show|delete|delete-expired|delete-fired|clear> [OPTIONS]"
    shift || true

    case "$subcommand" in
        list)
            local conversation=""
            local status_filter=""
            local order_by="id"

            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --conversation)
                        [[ -z "${2:-}" ]] && error "--conversation requires a value"
                        conversation="$2"
                        shift 2
                        ;;
                    --status)
                        [[ -z "${2:-}" ]] && error "--status requires a value"
                        status_filter="$2"
                        shift 2
                        ;;
                    --order-by)
                        [[ -z "${2:-}" ]] && error "--order-by requires a value (id|date)"
                        case "$2" in
                            id)   order_by="id" ;;
                            date) order_by="due_at ASC" ;;
                            *)    error "--order-by must be one of: id, date" ;;
                        esac
                        shift 2
                        ;;
                    --help|-h)
                        echo "Usage: joi-admin reminders list [--conversation ID] [--status STATUS] [--order-by id|date]"
                        exit 0
                        ;;
                    *)
                        error "Unknown option for 'reminders list': $1"
                        ;;
                esac
            done

            local where_parts=()
            if [[ -n "$conversation" ]]; then
                local conv_esc
                conv_esc=$(sql_escape_literal "$conversation")
                where_parts+=("conversation_id = '$conv_esc'")
            fi
            if [[ -n "$status_filter" ]]; then
                local stat_esc
                stat_esc=$(sql_escape_literal "$status_filter")
                where_parts+=("status = '$stat_esc'")
            fi

            local where_clause=""
            if [[ ${#where_parts[@]} -gt 0 ]]; then
                where_clause="WHERE $(IFS=' AND '; echo "${where_parts[*]}")"
            fi

            local rows
            rows=$(db_exec "$(cat <<SQL
SELECT
    id,
    conversation_id,
    title,
    due_at,
    status,
    COALESCE(recurrence, '-'),
    snooze_count
FROM reminders
$where_clause
ORDER BY $order_by;
SQL
)" | awk 'NF && $0 != "ok"')

            if [[ -z "${rows//[$'\t\r\n ']/}" ]]; then
                echo "No reminders found."
                exit 0
            fi

            printf "%-4s  %-20s  %-30s  %-20s  %-10s  %-10s  %s\n" \
                "ID" "conversation_id" "title" "due_at" "status" "recurrence" "snoozes"
            printf "%-4s  %-20s  %-30s  %-20s  %-10s  %-10s  %s\n" \
                "----" "--------------------" "------------------------------" \
                "--------------------" "----------" "----------" "-------"
            while IFS='|' read -r id conv title due stat recur snoozes; do
                [[ -z "$id" ]] && continue
                due_disp=$(TZ="${JOI_TIMEZONE:-Europe/Bratislava}" date -d "${due}" +"%Y-%m-%dT%H:%M" 2>/dev/null || echo "${due:0:20}")
                printf "%-4s  %-20s  %-30s  %-20s  %-10s  %-10s  %s\n" \
                    "$id" "${conv:0:20}" "${title:0:30}" "${due_disp:0:20}" \
                    "${stat:0:10}" "${recur:0:10}" "$snoozes"
            done <<< "$rows"
            ;;

        show)
            local reminder_id="${1:-}"
            if [[ -z "$reminder_id" || "$reminder_id" == "--help" || "$reminder_id" == "-h" ]]; then
                echo "Usage: joi-admin reminders show <id>"
                echo ""
                echo "Show all fields for a single reminder."
                exit 0
            fi
            [[ ! "$reminder_id" =~ ^[0-9]+$ ]] && error "Reminder id must be a number"

            local exists
            exists=$(db_scalar "SELECT COUNT(*) FROM reminders WHERE id = $reminder_id;")
            [[ "${exists:-0}" == "0" ]] && error "No reminder found with id $reminder_id"

            echo ""
            echo "=== REMINDER #$reminder_id ==="
            printf "  %-18s %s\n" "id:" "$(db_scalar "SELECT id FROM reminders WHERE id = $reminder_id;")"
            printf "  %-18s %s\n" "conversation_id:" "$(db_scalar "SELECT COALESCE(conversation_id,'') FROM reminders WHERE id = $reminder_id;")"
            printf "  %-18s %s\n" "title:" "$(db_scalar "SELECT COALESCE(title,'') FROM reminders WHERE id = $reminder_id;")"
            printf "  %-18s %s\n" "due_at:" "$(db_scalar "SELECT COALESCE(due_at,'-') FROM reminders WHERE id = $reminder_id;")"
            printf "  %-18s %s\n" "status:" "$(db_scalar "SELECT COALESCE(status,'-') FROM reminders WHERE id = $reminder_id;")"
            printf "  %-18s %s\n" "recurrence:" "$(db_scalar "SELECT COALESCE(recurrence,'-') FROM reminders WHERE id = $reminder_id;")"
            printf "  %-18s %s\n" "created_at:" "$(db_scalar "SELECT COALESCE(created_at,'-') FROM reminders WHERE id = $reminder_id;")"
            printf "  %-18s %s\n" "fired_at:" "$(db_scalar "SELECT COALESCE(fired_at,'-') FROM reminders WHERE id = $reminder_id;")"
            printf "  %-18s %s\n" "expires_at:" "$(db_scalar "SELECT COALESCE(expires_at,'-') FROM reminders WHERE id = $reminder_id;")"
            printf "  %-18s %s\n" "snooze_count:" "$(db_scalar "SELECT COALESCE(snooze_count,0) FROM reminders WHERE id = $reminder_id;")"
            echo ""
            ;;

        delete)
            local reminder_id="${1:-}"
            if [[ -z "$reminder_id" || "$reminder_id" == "--help" || "$reminder_id" == "-h" ]]; then
                echo "Usage: joi-admin reminders delete <id>"
                echo ""
                echo "Delete a single reminder by ID (with confirmation)."
                exit 0
            fi
            [[ ! "$reminder_id" =~ ^[0-9]+$ ]] && error "Reminder id must be a number"

            local exists
            exists=$(db_scalar "SELECT COUNT(*) FROM reminders WHERE id = $reminder_id;")
            [[ "${exists:-0}" == "0" ]] && error "No reminder found with id $reminder_id"

            local title due status
            title=$(db_scalar "SELECT COALESCE(title,'') FROM reminders WHERE id = $reminder_id;")
            due=$(db_scalar "SELECT COALESCE(due_at,'-') FROM reminders WHERE id = $reminder_id;")
            status=$(db_scalar "SELECT COALESCE(status,'-') FROM reminders WHERE id = $reminder_id;")

            echo ""
            echo "=== DELETE REMINDER ==="
            printf "  ID:     %s\n" "$reminder_id"
            printf "  Title:  %s\n" "$title"
            printf "  Due:    %s\n" "$due"
            printf "  Status: %s\n" "$status"
            echo ""

            read -p "Delete this reminder? [y/N] " -n 1 -r
            echo
            if [[ ! $REPLY =~ ^[Yy]$ ]]; then
                echo "Aborted."
                exit 1
            fi

            db_exec "DELETE FROM reminders WHERE id = $reminder_id;"
            info "  Deleted reminder #$reminder_id"
            ;;

        clear)
            local conversation=""

            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --conversation)
                        [[ -z "${2:-}" ]] && error "--conversation requires a value"
                        conversation="$2"
                        shift 2
                        ;;
                    --help|-h)
                        echo "Usage: joi-admin reminders clear [--conversation ID]"
                        exit 0
                        ;;
                    *)
                        error "Unknown option for 'reminders clear': $1"
                        ;;
                esac
            done

            local count
            if [[ -n "$conversation" ]]; then
                local conv_esc
                conv_esc=$(sql_escape_literal "$conversation")
                count=$(db_scalar "SELECT COUNT(*) FROM reminders WHERE conversation_id = '$conv_esc';")
            else
                count=$(db_scalar "SELECT COUNT(*) FROM reminders;")
            fi

            if [[ "${count:-0}" == "0" ]]; then
                echo "No reminders found${conversation:+ for conversation '$conversation'}."
                exit 0
            fi

            echo ""
            echo "=== REMINDERS CLEAR SUMMARY ==="
            [[ -n "$conversation" ]] && echo "  Conversation: $conversation" || echo "  Scope: ALL conversations"
            echo "  Reminders to delete: $count"
            echo ""

            read -p "Delete $count reminder(s)? [y/N] " -n 1 -r
            echo
            if [[ ! $REPLY =~ ^[Yy]$ ]]; then
                echo "Aborted."
                exit 1
            fi

            if [[ -n "$conversation" ]]; then
                local conv_esc
                conv_esc=$(sql_escape_literal "$conversation")
                db_exec "DELETE FROM reminders WHERE conversation_id = '$conv_esc';"
            else
                db_exec "DELETE FROM reminders;"
            fi

            info "Deleted $count reminder(s)"
            ;;

        --help|-h)
            cat <<'HELP'
Usage: joi-admin reminders <subcommand> [OPTIONS]

Subcommands:
  list            [--conversation ID] [--status STATUS] [--order-by id|date]
  show            <id>
  delete          <id>
  delete-expired  Delete all reminders past their expiry time
  delete-fired    Delete all reminders with status 'fired'
  clear           [--conversation ID]

Examples:
  joi-admin reminders list
  joi-admin reminders show 3
  joi-admin reminders delete 3
  joi-admin reminders delete-expired
  joi-admin reminders delete-fired
  joi-admin reminders clear --conversation +1234567890
HELP
            exit 0
            ;;
        delete-expired)
            local count
            count=$(db_scalar "SELECT COUNT(*) FROM reminders WHERE expires_at < datetime('now');")

            if [[ "${count:-0}" == "0" ]]; then
                echo "No expired reminders found."
                exit 0
            fi

            echo ""
            echo "=== DELETE EXPIRED REMINDERS ==="
            echo "  Reminders to delete: $count"
            echo ""

            read -p "Delete $count expired reminder(s)? [y/N] " -n 1 -r
            echo
            if [[ ! $REPLY =~ ^[Yy]$ ]]; then
                echo "Aborted."
                exit 1
            fi

            db_exec "DELETE FROM reminders WHERE expires_at < datetime('now');"
            info "Deleted $count expired reminder(s)"
            ;;

        delete-fired)
            local count
            count=$(db_scalar "SELECT COUNT(*) FROM reminders WHERE status = 'fired';")

            if [[ "${count:-0}" == "0" ]]; then
                echo "No fired reminders found."
                exit 0
            fi

            echo ""
            echo "=== DELETE FIRED REMINDERS ==="
            echo "  Reminders to delete: $count"
            echo ""

            read -p "Delete $count fired reminder(s)? [y/N] " -n 1 -r
            echo
            if [[ ! $REPLY =~ ^[Yy]$ ]]; then
                echo "Aborted."
                exit 1
            fi

            db_exec "DELETE FROM reminders WHERE status = 'fired';"
            info "Deleted $count fired reminder(s)"
            ;;

        *)
            error "Unknown reminders subcommand: $subcommand"
            ;;
    esac
}

# Nuke command - drop all tables
cmd_nuke() {
    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
        cat <<'HELP'
Usage: joi-admin nuke

Drop ALL tables in the memory database. Cannot be undone.
joi-api will recreate a fresh empty schema on next start.

Tables dropped:
  messages              Chat history (inbound + outbound)
  user_facts            Long-term memory about the user
  context_summaries     Compressed conversation history
  knowledge_chunks      RAG knowledge base (ingested documents)
  wind_state            Wind proactive messaging state per conversation
  pending_topics        Wind topic queue
  topic_feedback        Topic family preferences, cooldowns, undertaker
  wind_decision_log     Wind tick decision audit log
  reminders             User reminders
  system_state          Internal operational key-value state
  knowledge_fts         FTS index for knowledge_chunks
  user_facts_fts        FTS index for user_facts
  summaries_fts         FTS index for context_summaries
  (and all associated FTS triggers)
HELP
        exit 0
    fi

    if [[ ! -f "$MEMORY_DB" ]]; then
        error "Memory database not found: $MEMORY_DB"
    fi

    # Warn if joi-api is actively running — dropping tables under a live service
    # can cause SQLite lock errors or application crashes.
    if command -v systemctl >/dev/null 2>&1 && systemctl is-active --quiet joi 2>/dev/null; then
        warn "joi service is currently running. Stop it before nuking to avoid lock errors."
        warn "  sudo systemctl stop joi"
        echo ""
    fi

    echo ""
    echo "=== NUKE ==="
    echo "This will DROP ALL TABLES in: $MEMORY_DB"
    echo "All messages, facts, summaries, knowledge, Wind state and topics will be"
    echo "permanently deleted. joi-api will recreate a fresh schema on next start."
    echo ""

    read -p "Delete ALL data? [y/N] " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        echo "Aborted."
        exit 1
    fi

    echo "Type \"nuke\" to confirm (anything else aborts):"
    read -r NUKE_CONFIRM
    if [[ "$NUKE_CONFIRM" != "nuke" ]]; then
        echo "Aborted."
        exit 1
    fi

    db_exec "$(cat <<'SQL'
DROP TABLE IF EXISTS knowledge_fts;
DROP TABLE IF EXISTS user_facts_fts;
DROP TABLE IF EXISTS summaries_fts;
DROP TRIGGER IF EXISTS knowledge_ai;
DROP TRIGGER IF EXISTS knowledge_ad;
DROP TRIGGER IF EXISTS knowledge_au;
DROP TRIGGER IF EXISTS facts_ai;
DROP TRIGGER IF EXISTS facts_ad;
DROP TRIGGER IF EXISTS facts_au;
DROP TRIGGER IF EXISTS summaries_ai;
DROP TRIGGER IF EXISTS summaries_ad;
DROP TRIGGER IF EXISTS summaries_au;
DROP TABLE IF EXISTS messages;
DROP TABLE IF EXISTS user_facts;
DROP TABLE IF EXISTS context_summaries;
DROP TABLE IF EXISTS knowledge_chunks;
DROP TABLE IF EXISTS wind_state;
DROP TABLE IF EXISTS pending_topics;
DROP TABLE IF EXISTS topic_feedback;
DROP TABLE IF EXISTS wind_decision_log;
DROP TABLE IF EXISTS reminders;
DROP TABLE IF EXISTS system_state;
DELETE FROM sqlite_sequence;
SQL
)"

    info "  Dropped all tables."

    db_exec "VACUUM;"
    info "  Vacuumed database."
    info "  Done. Restart joi-api to recreate a fresh schema."
}

main() {
    if [[ $# -lt 1 ]]; then
        usage
    fi

    local command="$1"
    shift

    case "$command" in
        purge)
            check_root
            cmd_purge "$@"
            ;;
        facts)
            check_root
            cmd_facts "$@"
            ;;
        reminders)
            check_root
            cmd_reminders "$@"
            ;;
        rag)
            check_root
            cmd_rag "$@"
            ;;
        summaries)
            check_root
            cmd_summaries "$@"
            ;;
        fts)
            check_root
            cmd_fts "$@"
            ;;
        wind)
            check_root
            cmd_wind "$@"
            ;;
        nuke)
            check_root
            cmd_nuke "$@"
            ;;
        --help|-h)
            usage
            ;;
        *)
            error "Unknown command: $command. Run '$SCRIPT_NAME --help' for usage."
            ;;
    esac
}

main "$@"
