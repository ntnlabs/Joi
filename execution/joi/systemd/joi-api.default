# /etc/default/joi-api
# Environment variables for Joi API service
# Copy to /etc/default/joi-api and adjust as needed

# --- Core ---
# Bind to Nebula IP only (more secure than 0.0.0.0)
# Replace with your Joi VM's Nebula IP (e.g., 10.42.0.10)
JOI_BIND_HOST=10.42.0.10
JOI_BIND_PORT=8443

# --- Logging ---
# Set to 1 for JSON structured logs, 0 for human-readable text (default)
#JOI_LOG_JSON=0
#JOI_LOG_LEVEL=INFO
# Set to 1 to write one YAML file per LLM call with full context (facts, summaries, RAG, messages)
# WARNING: logs unredacted conversation content — disable when not debugging
#JOI_BRAIN_DEBUG=0
#JOI_BRAIN_DEBUG_DIR=/var/lib/joi/llm_debug

# --- Message Limits ---
# Max input length (chars) - messages exceeding this are rejected
#JOI_MAX_INPUT_LENGTH=1500
# Max output length (Signal supports up to ~6000 chars)
#JOI_MAX_OUTPUT_LENGTH=2000

# --- Signal Formatting ---
# Convert **bold** to Unicode bold characters (Signal doesn't support markdown)
JOI_SIGNAL_FORMAT_ENABLED=1

# --- LLM ---
JOI_OLLAMA_URL=http://localhost:11434
JOI_OLLAMA_MODEL=llama3
JOI_LLM_TIMEOUT=300
# How long to keep model loaded in VRAM after request (e.g., 30m, 1h, 0 to unload immediately)
JOI_LLM_KEEP_ALIVE=30m
# Context window size - prefer setting this in Modelfile (PARAMETER num_ctx)
# This env var overrides Modelfile if set. Use 0 or leave unset to use Modelfile value.
# Only use as fallback when you can't control the Modelfile.
#JOI_OLLAMA_NUM_CTX=0
# Translation model prefix - derives inbound/outbound model names as {prefix}-{lang}-en / {prefix}-en-{lang}
# Requires per-user/group .translate file with language code (e.g., "sk") to enable
#JOI_TRANSLATE_MODEL_PREFIX=translategemma

# --- Mesh ---
# Mesh proxy URL (Nebula IP)
JOI_MESH_URL=http://10.42.0.1:8444
# Path to mesh policy file (pushed to mesh on config sync)
#JOI_MESH_POLICY_PATH=/var/lib/joi/policy/mesh-policy.json

# --- Memory ---
JOI_MEMORY_DB=/var/lib/joi/memory.db
# SQLCipher encryption key file path
# Generate with: sudo /opt/Joi/execution/joi/scripts/generate-memory-key.sh
JOI_MEMORY_KEY_FILE=/etc/joi/memory.key
# Nonce replay-protection database
#JOI_NONCE_DB=/var/lib/joi/nonces.db
JOI_CONTEXT_MESSAGES=50
# Require encrypted database (set to 0 to allow unencrypted - NOT RECOMMENDED)
JOI_REQUIRE_ENCRYPTED_DB=1

# --- Compaction ---
# When messages exceed context size, compact oldest N messages
# Constraint: 10 <= batch < context // 2
#JOI_COMPACT_BATCH_SIZE=20
# Optional: separate model for consolidation (low temperature recommended)
#JOI_CONSOLIDATION_MODEL=joi-consolidator

# --- Message Retention ---
# Time-based purge of fully-processed messages (compacted + Wind-mined).
# 0 = disabled (default — messages kept forever). Max 90 days.
#JOI_MESSAGE_RETENTION_DAYS=0

# --- Wind Engagement ---
# Model for classifying user responses to proactive messages
#JOI_ENGAGEMENT_MODEL=joi-engagement
# Model for mining open conversation threads (tension topics)
#JOI_CURIOSITY_MODEL=joi-curiosity
# Model for structured intent detection (facts, mood, reminders, notes, agenda)
# Falls back to JOI_CURIOSITY_MODEL if not set
#JOI_DETECTOR_MODEL=joi-detector
# Minutes of user silence before mining unprocessed messages for tension topics
# Must be less than both min_silence_minutes (default: 30) and min_cooldown_minutes (default: 60)
# so mining happens before Wind's gates open
#JOI_TENSION_SILENCE_MINUTES=20
# How long wind topic outcome summaries stay active for deduplication (days)
#JOI_WIND_OUTCOME_TTL_DAYS=90
# How far back to search conversation history when generating topic outcome summaries (days)
#JOI_WIND_OUTCOME_HISTORY_DAYS=180

# Wind mood momentum: intensity nudge per heated message (0 = disable)
#JOI_WIND_MOMENTUM_NUDGE=0.05
# Topic priority decay: base points subtracted per day (scales with queue depth via sqrt)
#WIND_TOPIC_PRIORITY_DECAY_POINTS=4
# Queue depth at which decay equals base_points exactly (set to 0 to disable decay)
#WIND_TOPIC_PRIORITY_DECAY_REFERENCE=8
# Fraction of decay restored for topic families the user likes (0.0–1.0, 0 = disable)
#WIND_TOPIC_PRIORITY_AFFINITY_FACTOR=0.5
# Preference score (interest - rejection) at which an undertaker family is organically released
#WIND_TOPIC_PRIORITY_UNDERTAKER_RELEASE_THRESHOLD=0.5
# Wake-up procedure: minimum silence (hours) before triggering
#WIND_WAKEUP_FLOOR_HOURS=72
# Wake-up procedure: maximum threshold — wake-up always fires within this window (hours)
#WIND_WAKEUP_CAP_HOURS=96
# Wake-up procedure: EMA gap multiplier (nudges threshold between floor and cap)
#WIND_WAKEUP_EMA_MULTIPLIER=3.0

# --- RAG ---
# Set to 0 to disable knowledge retrieval
JOI_RAG_ENABLED=1
# Max tokens for RAG context in prompts
#JOI_RAG_MAX_TOKENS=1500
# Ollama embedding model for semantic search (leave empty to use BM25 FTS only)
# Pull with: ollama pull bge-m3
#JOI_EMBEDDING_MODEL=bge-m3
# Force embedding requests to CPU (num_gpu=0). Default ON to work around a
# bge-m3 + flash-attention NaN bug that causes Ollama to 500 on certain
# token sequences. Set to 0 only if your model+server combo is known good.
#JOI_EMBED_CPU_ONLY=1
# Minimum cosine similarity for semantic RAG (0.0 = no filter, 1.0 = exact match only)
#JOI_RAG_MIN_SIMILARITY=0.45
# Minimum BM25 score for FTS RAG fallback (0.0 = no filter, more negative = stricter)
#JOI_RAG_MIN_BM25=-0.5

# Hybrid retrieval tunables (Search Rework v1)
# RRF smoothing constant — controls consensus emphasis (default 60)
#JOI_RRF_K=60
# Top-N pulled from each retriever before fusion (default 20)
#JOI_RRF_TOP_N=20

# --- Facts & Summaries FTS ---
# Full-text search context injection (facts and conversation summaries)
#JOI_FACTS_FTS_ENABLED=1
#JOI_FACTS_FTS_MAX_TOKENS=400
#JOI_SUMMARIES_FTS_ENABLED=1
#JOI_SUMMARIES_FTS_MAX_TOKENS=1500
#JOI_FTS_CONTEXT_MESSAGES=3
#JOI_FTS_HOT_BOOST=1
#JOI_FTS_HEATED_BOOST=2

# --- Knowledge Ingestion ---
# Directory watched for new knowledge files to ingest into RAG
#JOI_INGESTION_DIR=/var/lib/joi/ingestion
# Set to 1 to keep source files after ingestion (default: delete)
#JOI_INGESTION_KEEP_FILES=0
# Chunk size and overlap for RAG ingestion (tokens)
#JOI_INGESTION_CHUNK_SIZE=500
#JOI_INGESTION_OVERLAP=50
# Max document size in bytes (should match MESH_MAX_DOCUMENT_SIZE on Mesh VM)
# Joi's ingest guard is 2x this value as a safety margin above the mesh cap
#JOI_MAX_DOCUMENT_SIZE=1048576

# --- Response Cooldown ---
# Minimum seconds between outbound responses (prevents flooding)
#JOI_RESPONSE_COOLDOWN_SECONDS=5.0
#JOI_RESPONSE_COOLDOWN_GROUP_SECONDS=2.0
# Max outbound messages per hour (across all conversations)
#JOI_OUTBOUND_MAX_PER_HOUR=120

# --- Group Membership ---
# How often to refresh group membership cache (minutes)
#JOI_MEMBERSHIP_REFRESH_MINUTES=15

# --- Reminders ---
# How long to retain fired/expired/cancelled reminders (days). 0 = keep forever.
#JOI_REMINDER_RETENTION_DAYS=180

# Time-of-day definitions for reminder commands (hours in 24h local time)
#JOI_REMINDER_EARLY_MORNING_HOUR=6
#JOI_REMINDER_MORNING_HOUR=8
#JOI_REMINDER_LUNCH_HOUR=12
#JOI_REMINDER_AFTERNOON_HOUR=16
#JOI_REMINDER_EVENING_HOUR=19
#JOI_REMINDER_TONIGHT_HOUR=21
#JOI_REMINDER_LATE_NIGHT_HOUR=23
# How long after a reminder fires that "snooze" still refers to it (minutes)
#JOI_REMINDER_SNOOZE_WINDOW_MINUTES=45
# Default snooze duration when no duration is specified (minutes)
#JOI_REMINDER_SNOOZE_DEFAULT_MINUTES=30

# --- Scheduler (Wind/Tasks) ---
# Background scheduler for proactive messaging and reminders
JOI_SCHEDULER_ENABLED=1
# Tick interval in seconds
JOI_SCHEDULER_INTERVAL=60
# Seconds to wait after startup before first tick
JOI_SCHEDULER_STARTUP_DELAY=10

# --- Prompts ---
# Directory for per-user and per-group system prompts
JOI_PROMPTS_DIR=/var/lib/joi/prompts

# --- HMAC Authentication (defense-in-depth over Nebula) ---
# Shared secret for HMAC verification (MUST match MESH_HMAC_SECRET on Mesh VM)
# Generate with: openssl rand -hex 32
JOI_HMAC_SECRET=<your-256-bit-hex-secret>
# Timestamp tolerance in milliseconds (default: 300000 = 5 minutes)
#JOI_HMAC_TIMESTAMP_TOLERANCE_MS=300000
# Path to rotated HMAC secret file (managed automatically by joi-admin)
#JOI_HMAC_SECRET_FILE=/var/lib/joi/hmac.secret
