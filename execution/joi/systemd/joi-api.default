# /etc/default/joi-api
# Environment variables for Joi API service
# Copy to /etc/default/joi-api and adjust as needed

# --- Core ---
# Bind to Nebula IP only (more secure than 0.0.0.0)
# Replace with your Joi VM's Nebula IP (e.g., 10.42.0.10)
JOI_BIND_HOST=10.42.0.10
JOI_BIND_PORT=8443

# --- Logging ---
# Set to 1 for JSON structured logs, 0 for human-readable text (default)
#JOI_LOG_JSON=0
#JOI_LOG_LEVEL=INFO

# --- Message Limits ---
# Max input length (chars) - messages exceeding this are rejected
#JOI_MAX_INPUT_LENGTH=1500
# Max output length (Signal supports up to ~6000 chars)
#JOI_MAX_OUTPUT_LENGTH=2000

# --- Signal Formatting ---
# Convert **bold** to Unicode bold characters (Signal doesn't support markdown)
JOI_SIGNAL_FORMAT_ENABLED=1

# --- LLM ---
JOI_OLLAMA_URL=http://localhost:11434
JOI_OLLAMA_MODEL=llama3
JOI_LLM_TIMEOUT=180
# How long to keep model loaded in VRAM after request (e.g., 30m, 1h, 0 to unload immediately)
JOI_LLM_KEEP_ALIVE=30m
# Context window size - prefer setting this in Modelfile (PARAMETER num_ctx)
# This env var overrides Modelfile if set. Use 0 or leave unset to use Modelfile value.
# Only use as fallback when you can't control the Modelfile.
#JOI_OLLAMA_NUM_CTX=0

# --- Mesh ---
# Mesh proxy URL (Nebula IP)
JOI_MESH_URL=http://10.42.0.1:8444
# Path to mesh policy file (pushed to mesh on config sync)
#JOI_MESH_POLICY_PATH=/var/lib/joi/policy/mesh-policy.json

# --- Memory ---
JOI_MEMORY_DB=/var/lib/joi/memory.db
# SQLCipher encryption key file path
#JOI_MEMORY_KEY_FILE=/etc/joi/memory.key
# SQLCipher encryption key (inline, alternative to key file)
#JOI_MEMORY_KEY=<generate-with-openssl-rand-base64-32>
# Nonce replay-protection database
#JOI_NONCE_DB=/var/lib/joi/nonces.db
JOI_CONTEXT_MESSAGES=50
# Require encrypted database (set to 0 to allow unencrypted - NOT RECOMMENDED)
JOI_REQUIRE_ENCRYPTED_DB=1

# --- Compaction ---
# When messages exceed context size, compact oldest N messages
# Constraint: 10 <= batch < context // 2
#JOI_COMPACT_BATCH_SIZE=20
# Set to 1 to archive messages instead of deleting
JOI_CONSOLIDATION_ARCHIVE=0
# Optional: separate model for consolidation (low temperature recommended)
#JOI_CONSOLIDATION_MODEL=joi-consolidator

# --- Wind Engagement ---
# Model for classifying user responses to proactive messages
#JOI_ENGAGEMENT_MODEL=joi-engagement

# --- RAG ---
# Set to 0 to disable knowledge retrieval
JOI_RAG_ENABLED=1
# Max tokens for RAG context in prompts
#JOI_RAG_MAX_TOKENS=1500
# Ollama embedding model for semantic search (leave empty to use BM25 FTS only)
# Pull with: ollama pull nomic-embed-text
#JOI_EMBEDDING_MODEL=

# --- Facts & Summaries FTS ---
# Full-text search context injection (facts and conversation summaries)
#JOI_FACTS_FTS_ENABLED=1
#JOI_FACTS_FTS_MAX_TOKENS=300
#JOI_SUMMARIES_FTS_ENABLED=1
#JOI_SUMMARIES_FTS_MAX_TOKENS=1500

# --- Knowledge Ingestion ---
# Directory watched for new knowledge files to ingest into RAG
#JOI_INGESTION_DIR=/var/lib/joi/ingestion
# Set to 1 to keep source files after ingestion (default: delete)
#JOI_INGESTION_KEEP_FILES=0
# Chunk size and overlap for RAG ingestion (tokens)
#JOI_INGESTION_CHUNK_SIZE=500
#JOI_INGESTION_OVERLAP=50
# Max document size in bytes (should match MESH_MAX_DOCUMENT_SIZE on Mesh VM)
# Joi's ingest guard is 2x this value as a safety margin above the mesh cap
#JOI_MAX_DOCUMENT_SIZE=1048576

# --- Time Awareness ---
# Set to 1 to inject current datetime into system prompt
# Enables appropriate greetings and understanding of relative time
JOI_TIME_AWARENESS=0
# User timezone in IANA format (e.g., Europe/Bratislava, America/New_York)
JOI_TIMEZONE=Europe/Bratislava

# --- Response Cooldown ---
# Minimum seconds between outbound responses (prevents flooding)
#JOI_RESPONSE_COOLDOWN_SECONDS=5.0
#JOI_RESPONSE_COOLDOWN_GROUP_SECONDS=2.0
# Max outbound messages per hour (across all conversations)
#JOI_OUTBOUND_MAX_PER_HOUR=120

# --- Group Membership ---
# How often to refresh group membership cache (minutes)
#JOI_MEMBERSHIP_REFRESH_MINUTES=15

# --- Scheduler (Wind/Tasks) ---
# Background scheduler for proactive messaging and reminders
JOI_SCHEDULER_ENABLED=1
# Tick interval in seconds
JOI_SCHEDULER_INTERVAL=60
# Seconds to wait after startup before first tick
JOI_SCHEDULER_STARTUP_DELAY=10

# --- Prompts ---
# Directory for per-user and per-group system prompts
JOI_PROMPTS_DIR=/var/lib/joi/prompts

# --- HMAC Authentication (defense-in-depth over Nebula) ---
# Shared secret for HMAC verification (MUST match MESH_HMAC_SECRET on Mesh VM)
# Generate with: openssl rand -hex 32
JOI_HMAC_SECRET=<your-256-bit-hex-secret>
# Timestamp tolerance in milliseconds (default: 300000 = 5 minutes)
#JOI_HMAC_TIMESTAMP_TOLERANCE_MS=300000
# Path to rotated HMAC secret file (managed automatically by joi-admin)
#JOI_HMAC_SECRET_FILE=/var/lib/joi/hmac.secret
