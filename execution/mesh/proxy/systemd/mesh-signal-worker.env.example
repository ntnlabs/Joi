# /etc/default/mesh-signal-worker
# Environment variables for Mesh Signal Worker service
# Copy to /etc/default/mesh-signal-worker and adjust as needed

# --- Required ---
SIGNAL_ACCOUNT=+<COUNTRY><NUMBER>
MESH_ENABLE_FORWARD=1
MESH_JOI_URL=http://<JOI_NEBULA_IP>:8443
# MESH_HMAC_SECRET is no longer required. Mesh receives its HMAC key from Joi on first
# push (bootstrap). The key is held in memory only — mesh restart clears it and Joi
# re-bootstraps automatically within ~60 s.
# Set this only as an emergency fallback for existing deployments during transition.
#MESH_HMAC_SECRET=<your-256-bit-hex-secret>

# --- Logging ---
# Set to 1 for JSON structured logs, 0 for human-readable text (default)
#MESH_LOG_JSON=0
#MESH_LOG_LEVEL=INFO

# --- Optional (defaults shown) ---
#MESH_FORWARD_TIMEOUT=280
#MESH_WORKER_HTTP_PORT=8444
#SIGNAL_CLI_BIN=/usr/local/bin/signal-cli
#SIGNAL_CLI_CONFIG_DIR=/var/lib/signal-cli
# Consecutive watchdog cycles with no Joi contact before HMAC key is cleared (default: 2 = ~120 s)
#MESH_CONFIG_STALENESS_CHECKS=2
